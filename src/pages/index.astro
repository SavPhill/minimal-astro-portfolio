  <!-- LIVE CHIANG MAI CLOCK SCRIPT -->
  <script>
    function updateChiangMaiTime() {
      const clockElement = document.getElementById('live-time');
      if (!clockElement) return;

      const now = new Date();
      const options: Intl.DateTimeFormatOptions = {
        timeZone: 'Asia/Bangkok',
        hour: '2-digit',
        minute: '2-digit',
        second: '2-digit',
        hour12: false
      };
      
      const timeString = new Intl.DateTimeFormat([], options).format(now);
      clockElement.textContent = `${timeString} ICT`;
    }

    updateChiangMaiTime();
    setInterval(updateChiangMaiTime, 1000);
    
    document.addEventListener('astro:after-swap', () => {
      updateChiangMaiTime();
    });
  </script>
