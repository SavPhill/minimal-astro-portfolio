---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostList from '../components/PostList.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts');
const sortedPosts = allPosts.sort((a, b) => {
  return new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf();
});

const posts = sortedPosts.slice(0, 5).map(post => ({
  ...post,
  url: `/posts/${post.id}`,
  frontmatter: post.data
}));
---

<BaseLayout title="Phill | Generative Search Architect">
  <div class="max-w-4xl mx-auto">
    <section class="text-center py-[10vh]" transition:animate="fade">
      <h1 class="text-5xl md:text-7xl mb-8 font-bold tracking-tight">
        Traditional SEO is Changing. 
 <span class="text-blue-600">Position Your Business to Be Recommended by AI.</span>
      </h1>
      <p class="text-xl md:text-2xl text-muted-foreground max-w-3xl mx-auto mb-14 leading-relaxed">
        I’m Phill, a Generative Search Architect. I help brands secure their place in the "Answer Era" by optimizing for AI discovery. If ChatGPT isn't recommending you, your competitors are already winning.
      </p>
      
      <a href="mailto:hello@psavage.net?subject=AI%20Visibility%20Audit%20Request" class="btn-primary btn-lg tracking-wide no-underline hover:no-underline transform transition-all duration-300 hover:scale-105 hover:shadow-[0_3.5rem_5rem_rgba(21,21,21,0.3)] shadow-[0_3rem_4rem_rgba(21,21,21,0.25)] dark:bg-white dark:text-black dark:hover:bg-gray-100">
  Get Your AI Visibility Audit
</a>
      
      <p class="mt-8 text-sm text-muted-foreground italic">
        10+ Years of Digital Strategy with Ace Marketing Solutions Thailand
      </p>
    </section>

    <section class="mx-auto mt-10" transition:animate="fade">
      <h2 class="text-xs uppercase tracking-[0.2em] font-semibold text-muted-foreground mb-12 text-center">
        Latest Intelligence
      </h2>
      
      <PostList 
        posts={posts} 
        showImages={false} 
        showExcerpt={true} 
        showSeparators={true} 
        showTags={true}
      />

      <div class="text-center mt-20">
        <a href="/journal" class="text-lg font-medium text-black dark:text-white py-2 px-4 rounded-md inline-block focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 hover:underline">
          All Posts <span aria-hidden="true">→</span>
        </a>
      </div>
    </section>
  </div>
</BaseLayout>