---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Fetch and sort the most recent 3 blog posts
const allPosts = await getCollection('posts');
const recentPosts = allPosts
  .sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf())
  .slice(0, 3);

const strategistSchema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "Phill Savage — Web Strategy & B2B Lead Generation",
  "url": "https://psavage.net",
  "image": "https://psavage.net/images/phill.jpg",
  "description": "Strategic web architecture, B2B lead generation, and Generative Engine Optimization (GEO) engineered to drive predictable pipeline for tech companies.",
  "provider": {
    "@type": "Organization",
    "name": "Ace Marketing Solutions",
    "url": "https://acemsthailand.com"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Chiang Mai",
    "addressCountry": "TH"
  },
  "sameAs": [
    "https://acemsthailand.com",
    "https://x.com/savphill",
    "https://th.linkedin.com/in/phill-savage"
  ]
};
---

<BaseLayout 
  title="Web Strategy, B2B Lead Generation & GEO | Phill Savage"
  description="I build high-converting web architecture, technical SEO/GEO blueprints, and B2B lead generation systems engineered to drive revenue and pipeline for scaling brands."
  keywords={[
    "Web Strategy", 
    "B2B Lead Generation",
    "Generative Engine Optimization", 
    "GEO Strategy", 
    "Technical SEO",
    "Astro Developer", 
    "B2B Demand Generation"
  ]}
  schema={strategistSchema}
>
  <!-- STICKY FLOATING CTA (Bottom Right) -->
  <div class="fixed bottom-6 right-6 z-50">
    <a 
      href="#strategy-inquiry" 
      class="flex items-center gap-2.5 px-4 py-3 rounded-full bg-blue-600 hover:bg-blue-500 text-white font-mono text-xs font-bold uppercase tracking-wider shadow-2xl transition-all transform hover:scale-105 border border-blue-400/40 backdrop-blur-md group"
    >
      <span class="relative flex h-2.5 w-2.5">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-cyan-300 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-cyan-400"></span>
      </span>
      <span>Request Pipeline Brief</span>
      <span class="group-hover:translate-x-0.5 transition-transform">→</span>
    </a>
  </div>

  <div class="relative overflow-hidden">
    <!-- Ambient Lighting FX -->
    <div class="absolute -top-40 -left-40 w-96 h-96 bg-blue-500/10 dark:bg-blue-600/15 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute top-1/3 -right-40 w-96 h-96 bg-cyan-500/10 dark:bg-cyan-500/15 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute bottom-1/4 -left-40 w-96 h-96 bg-teal-500/10 dark:bg-teal-500/15 rounded-full blur-3xl pointer-events-none"></div>

    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      
      <!-- HERO SECTION -->
      <section class="pt-6 pb-12 md:pt-10 md:pb-16" transition:animate="fade">
        
        <!-- Chiang Mai Clock & Availability Banner -->
        <div class="flex flex-wrap items-center gap-3 mb-8">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-slate-100 dark:bg-slate-800/90 border border-slate-200 dark:border-slate-700/60 text-xs font-mono text-slate-700 dark:text-slate-300 backdrop-blur-sm">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
            </span>
            <span>Chiang Mai HQ: <strong id="live-time" class="text-slate-900 dark:text-white font-semibold">--:-- ICT</strong></span>
          </div>

          <div class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-blue-50 dark:bg-blue-950/50 border border-blue-200/80 dark:border-blue-800/60 text-xs font-mono text-blue-700 dark:text-blue-300">
            <span>⚡ Accepting Growth & Lead Gen Clients</span>
          </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-start">
          
          <!-- Left Column: Identity & Value Proposition -->
          <div class="lg:col-span-7 text-left space-y-6">
            
            <!-- Profile Identity Card -->
            <div class="flex items-center gap-4 p-3.5 rounded-2xl bg-slate-50 dark:bg-slate-900/40 border border-slate-200/60 dark:border-slate-800/60">
              <img 
                src="/images/phill.jpg" 
                alt="Phill Savage — Client Director & Web Strategist" 
                width="96"
                height="96"
                class="w-20 h-20 sm:w-24 sm:h-24 rounded-2xl object-cover ring-2 ring-blue-500/40 shadow-xl flex-shrink-0"
              />
              <div>
                <span class="text-[11px] font-mono uppercase tracking-widest text-blue-600 dark:text-blue-400 font-bold block">// Principal Strategist</span>
                <h2 class="text-xl sm:text-2xl font-black text-slate-900 dark:text-white">Phill Savage</h2>
                <p class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">
                  Client Director @ Ace Marketing Solutions
                </p>
                <div class="flex items-center gap-2 mt-2">
                  <span class="inline-block w-2 h-2 rounded-full bg-emerald-500"></span>
                  <span class="text-[10px] font-mono text-slate-600 dark:text-slate-400">Direct Consultation • ~2hr Response</span>
                </div>
              </div>
            </div>

            <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black tracking-tight text-slate-900 dark:text-white leading-[1.1]">
              Web Strategy & <br class="hidden sm:inline" />
              <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 via-cyan-500 to-teal-400 dark:from-blue-400 dark:via-cyan-300 dark:to-teal-300">
                B2B Lead Gen.
              </span>
            </h1>
            
            <p class="text-lg md:text-xl font-normal text-slate-600 dark:text-slate-300 leading-relaxed">
              I align performant web architecture, technical SEO, and Generative Engine Optimization (GEO) into an active revenue system that captures modern AI search intent and drives qualified B2B pipeline. Backed by <a href="https://acemsthailand.com" target="_blank" rel="noopener noreferrer" class="underline hover:text-blue-600 font-semibold">Ace Marketing Solutions</a>.
            </p>

            <div class="flex flex-wrap gap-2 pt-2">
              <span class="text-xs font-mono px-2.5 py-1 rounded-md bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 border border-slate-200 dark:border-slate-700/50">
                🎯 B2B Lead Generation
              </span>
              <span class="text-xs font-mono px-2.5 py-1 rounded-md bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 border border-slate-200 dark:border-slate-700/50">
                🚀 Web Architecture
              </span>
              <span class="text-xs font-mono px-2.5 py-1 rounded-md bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 border border-slate-200 dark:border-slate-700/50">
                🤖 Generative Engine Optimization (GEO)
              </span>
            </div>

          </div>

          <!-- Right Column: Lead Form -->
          <div id="strategy-inquiry" class="lg:col-span-5 relative scroll-mt-12">
            <div class="absolute -inset-1 bg-gradient-to-r from-blue-600 to-cyan-500 rounded-3xl blur opacity-25 dark:opacity-40 transition duration-1000"></div>
            
            <div class="relative bg-white/95 dark:bg-slate-900/95 backdrop-blur-xl p-6 sm:p-7 rounded-2xl border border-slate-200/80 dark:border-slate-800 shadow-2xl">
              <div class="mb-4">
                <div class="flex items-center justify-between">
                  <h2 class="text-xl font-extrabold text-slate-900 dark:text-white">
                    Request Growth Audit
                  </h2>
                  <span class="text-[10px] font-mono px-2 py-0.5 rounded bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 border border-emerald-500/20 font-bold">
                    Active
                  </span>
                </div>
                <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">
                  Custom audits for web performance, conversion bottlenecks, or GEO visibility.
                </p>
              </div>
              
              <form 
                name="strategy-inquiry" 
                method="POST" 
                data-netlify="true" 
                netlify-honeypot="bot-field"
                class="space-y-3.5"
              >
                <input type="hidden" name="form-name" value="strategy-inquiry" />
                <p class="hidden"><label><input name="bot-field" /></label></p>

                <div>
                  <label for="name" class="block text-[10px] font-mono uppercase tracking-wider text-slate-500 dark:text-slate-400 mb-1">Your Name</label>
                  <input 
                    type="text" 
                    id="name" 
                    name="name" 
                    required 
                    placeholder="Jane Doe" 
                    class="w-full px-3.5 py-2 text-sm bg-slate-50 dark:bg-slate-950/80 border border-slate-200 dark:border-slate-800 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 text-slate-900 dark:text-white transition-all"
                  />
                </div>

                <div>
                  <label for="email" class="block text-[10px] font-mono uppercase tracking-wider text-slate-500 dark:text-slate-400 mb-1">Work Email</label>
                  <input 
                    type="email" 
                    id="email" 
                    name="email" 
                    required 
                    placeholder="jane@company.com" 
                    class="w-full px-3.5 py-2 text-sm bg-slate-50 dark:bg-slate-950/80 border border-slate-200 dark:border-slate-800 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 text-slate-900 dark:text-white transition-all"
                  />
                </div>

                <div>
                  <label for="website" class="block text-[10px] font-mono uppercase tracking-wider text-slate-500 dark:text-slate-400 mb-1">Website URL</label>
                  <input 
                    type="url" 
                    id="website" 
                    name="website" 
                    placeholder="https://yourcompany.com" 
                    class="w-full px-3.5 py-2 text-sm bg-slate-50 dark:bg-slate-950/80 border border-slate-200 dark:border-slate-800 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 text-slate-900 dark:text-white transition-all"
                  />
                </div>

                <div>
                  <label for="message" class="block text-[10px] font-mono uppercase tracking-wider text-slate-500 dark:text-slate-400 mb-1">Growth Goals / Pipeline Bottlenecks</label>
                  <textarea 
                    id="message" 
                    name="message" 
                    rows="3" 
                    placeholder="Low conversion rates, poor search visibility, expanding into AI answer engines..." 
                    class="w-full px-3.5 py-2 text-sm bg-slate-50 dark:bg-slate-950/80 border border-slate-200 dark:border-slate-800 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 text-slate-900 dark:text-white transition-all resize-none"
                  ></textarea>
                </div>

                <button 
                  type="submit" 
                  class="w-full py-3.5 px-4 text-xs font-bold uppercase tracking-wider text-white bg-gradient-to-r from-blue-600 to-cyan-600 hover:from-blue-500 hover:to-cyan-500 rounded-lg shadow-lg shadow-blue-500/25 transition-all transform active:scale-[0.98] mt-1 cursor-pointer"
                >
                  Request Proposal & Audit →
                </button>
              </form>

              <!-- FAIL-SAFE ALTERNATIVE CONTACT -->
              <div class="mt-4 pt-3 border-t border-slate-200/80 dark:border-slate-800/80 text-center">
                <p class="text-[11px] text-slate-500 dark:text-slate-400">
                  Prefer direct channel messaging?
                </p>
                <div class="flex items-center justify-center gap-3 mt-1.5 text-xs font-mono font-medium">
                  <a 
                    href="https://th.linkedin.com/in/phill-savage" 
                    target="_blank" 
                    rel="noopener noreferrer" 
                    class="text-blue-600 dark:text-blue-400 hover:underline flex items-center gap-1"
                  >
                    <span>LinkedIn Direct</span>
                  </a>
                  <span class="text-slate-300 dark:text-slate-700">•</span>
                  <a 
                    href="https://x.com/savphill" 
                    target="_blank" 
                    rel="noopener noreferrer" 
                    class="text-blue-600 dark:text-blue-400 hover:underline flex items-center gap-1"
                  >
                    <span>X / Twitter</span>
                  </a>
                </div>
              </div>

            </div>
          </div>

        </div>
      </section>

      <!-- PROOF & METRICS STRIP -->
      <section class="py-6 border-y border-slate-200/60 dark:border-slate-800/60 my-6">
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 text-center">
          <div>
            <div class="text-2xl font-black text-slate-900 dark:text-white font-mono">B2B Leads</div>
            <div class="text-xs text-slate-500 dark:text-slate-400 font-medium">Pipeline & Revenue Focus</div>
          </div>
          <div>
            <div class="text-2xl font-black text-slate-900 dark:text-white font-mono">GEO Ready</div>
            <div class="text-xs text-slate-500 dark:text-slate-400 font-medium">AI Answer Engine Authority</div>
          </div>
          <div>
            <div class="text-2xl font-black text-slate-900 dark:text-white font-mono">Astro 5+</div>
            <div class="text-xs text-slate-500 dark:text-slate-400 font-medium">High-Speed Stack</div>
          </div>
          <div>
            <div class="text-2xl font-black text-slate-900 dark:text-white font-mono">Ace MS</div>
            <div class="text-xs text-slate-500 dark:text-slate-400 font-medium">Full Agency Execution</div>
          </div>
        </div>
      </section>

      <!-- BRAND NEW: "DIGITAL MARKETING IS BROKEN" THESIS SECTION -->
      <section class="py-12 border-b border-slate-200/60 dark:border-slate-800/60" transition:animate="fade">
        <div class="p-8 sm:p-10 rounded-3xl bg-slate-900 text-white border border-slate-800 relative overflow-hidden shadow-2xl">
          <div class="absolute -right-20 -bottom-20 w-80 h-80 bg-blue-600/10 rounded-full blur-3xl pointer-events-none"></div>
          
          <div class="max-w-3xl space-y-4 text-left relative z-10">
            <span class="text-xs font-mono font-bold uppercase tracking-widest text-cyan-400">
              // Why Traditional Marketing Fails
            </span>
            <h2 class="text-2xl sm:text-3xl font-black tracking-tight text-white leading-tight">
              Most digital marketing is broken. We build revenue engines instead.
            </h2>
            <p class="text-sm sm:text-base text-slate-300 leading-relaxed font-normal">
              Traditional agencies sell disconnected tasks—a shiny web redesign here, a few blog posts or ad campaigns there. They check off their monthly retainer checklist, report on vanity clicks, and step away without taking responsibility for your pipeline.
            </p>
            <p class="text-sm sm:text-base text-slate-300 leading-relaxed font-normal">
              <strong>B2B Lead Generation isn't just "digital marketing."</strong> It's an engineered, full-stack ecosystem where web architecture, technical SEO, and GEO converge with a single objective: <em>turning search intent into qualified business revenue.</em>
            </p>
          </div>
        </div>
      </section>

      <!-- THREE CORE PILLARS SECTION -->
      <section class="py-12 border-t border-slate-200/60 dark:border-slate-800/60" transition:animate="fade">
        <div class="mb-10 text-left">
          <span class="text-xs font-mono uppercase tracking-widest text-blue-600 dark:text-blue-400 font-bold">// Core Architecture</span>
          <h2 class="text-3xl font-extrabold text-slate-900 dark:text-white mt-1">
            Engineered for pipeline growth in the AI search era
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          
          <div class="p-6 rounded-2xl bg-slate-50 dark:bg-slate-900/40 border border-slate-200/80 dark:border-slate-800 flex flex-col justify-between">
            <div>
              <div class="text-xs font-mono font-bold text-teal-600 dark:text-teal-400 uppercase tracking-widest mb-2">Pillar 01</div>
              <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-2">B2B Lead Gen & Funnel Strategy</h3>
              <p class="text-xs text-slate-600 dark:text-slate-400 leading-relaxed mb-4">
                Structuring high-intent buyer journeys, offer positioning, and conversion elements that turn traffic into sales-qualified leads and predictable pipeline.
              </p>
            </div>
            <div class="text-[11px] font-mono text-slate-500 dark:text-slate-400 border-t border-slate-200 dark:border-slate-800 pt-3">
              🎯 <strong>Focus:</strong> SQL Capture & Revenue Alignment
            </div>
          </div>

          <div class="p-6 rounded-2xl bg-slate-50 dark:bg-slate-900/40 border border-slate-200/80 dark:border-slate-800 flex flex-col justify-between">
            <div>
              <div class="text-xs font-mono font-bold text-cyan-600 dark:text-cyan-400 uppercase tracking-widest mb-2">Pillar 02</div>
              <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-2">Generative Engine Optimization (GEO)</h3>
              <p class="text-xs text-slate-600 dark:text-slate-400 leading-relaxed mb-4">
                Structuring entity graphs, nested schema metadata, and authoritative digital footprints so your brand gets recommended by ChatGPT, Perplexity, and Gemini.
              </p>
            </div>
            <div class="text-[11px] font-mono text-slate-500 dark:text-slate-400 border-t border-slate-200 dark:border-slate-800 pt-3">
              🤖 <strong>Focus:</strong> LLM Citations & AI Search Authority
            </div>
          </div>

          <div class="p-6 rounded-2xl bg-slate-50 dark:bg-slate-900/40 border border-slate-200/80 dark:border-slate-800 flex flex-col justify-between">
            <div>
              <div class="text-xs font-mono font-bold text-blue-600 dark:text-blue-400 uppercase tracking-widest mb-2">Pillar 03</div>
              <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-2">Modern Web Architecture</h3>
              <p class="text-xs text-slate-600 dark:text-slate-400 leading-relaxed mb-4">
                Building sub-second Jamstack platforms, custom Astro builds, and structured headless CMS setups optimized for UX, edge performance, and scale.
              </p>
            </div>
            <div class="text-[11px] font-mono text-slate-500 dark:text-slate-400 border-t border-slate-200 dark:border-slate-800 pt-3">
              ⚡ <strong>Focus:</strong> Core Web Vitals & Speed Optimization
            </div>
          </div>

        </div>
      </section>

      <!-- HOW IT WORKS BLUEPRINT -->
      <section class="py-12 border-t border-slate-200/60 dark:border-slate-800/60" transition:animate="fade">
        <div class="mb-10 text-left">
          <span class="text-xs font-mono uppercase tracking-widest text-blue-600 dark:text-blue-400 font-bold">// Strategic Process</span>
          <h2 class="text-3xl font-extrabold text-slate-900 dark:text-white mt-1">
            From Audit to Pipeline in 3 Steps
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="p-6 rounded-2xl bg-slate-50 dark:bg-slate-900/40 border border-slate-200/80 dark:border-slate-800">
            <div class="text-xs font-mono font-bold text-blue-600 dark:text-blue-400 uppercase tracking-widest mb-2">Step 01</div>
            <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-2">Digital Footprint & GEO Audit</h3>
            <p class="text-xs text-slate-600 dark:text-slate-400 leading-relaxed">
              We analyze your web technical architecture, conversion bottlenecks, search performance, and AI engine visibility.
            </p>
          </div>

          <div class="p-6 rounded-2xl bg-slate-50 dark:bg-slate-900/40 border border-slate-200/80 dark:border-slate-800">
            <div class="text-xs font-mono font-bold text-blue-600 dark:text-blue-400 uppercase tracking-widest mb-2">Step 02</div>
            <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-2">B2B Growth Blueprint</h3>
            <p class="text-xs text-slate-600 dark:text-slate-400 leading-relaxed">
              Receive an itemized roadmap covering site performance refactoring, schema implementation, content strategy, and lead generation funnels.
            </p>
          </div>

          <div class="p-6 rounded-2xl bg-slate-50 dark:bg-slate-900/40 border border-slate-200/80 dark:border-slate-800">
            <div class="text-xs font-mono font-bold text-blue-600 dark:text-blue-400 uppercase tracking-widest mb-2">Step 03</div>
            <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-2">Managed Implementation</h3>
            <p class="text-xs text-slate-600 dark:text-slate-400 leading-relaxed">
              In tandem with Ace Marketing Solutions and technical partners, we execute the builds, measure conversion performance, and scale your pipeline.
            </p>
          </div>
        </div>
      </section>

      <!-- WHO THIS IS FOR vs NOT A FIT -->
      <section class="py-12 border-t border-slate-200/60 dark:border-slate-800/60" transition:animate="fade">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          
          <div class="p-6 rounded-2xl bg-emerald-50/50 dark:bg-emerald-950/20 border border-emerald-200/80 dark:border-emerald-800/50">
            <h3 class="text-lg font-bold text-emerald-950 dark:text-emerald-300 flex items-center gap-2 mb-3">
              <span>✓ Ideal Engagement For:</span>
            </h3>
            <ul class="space-y-2.5 text-xs text-slate-700 dark:text-slate-300">
              <li class="flex items-start gap-2">
                <span class="text-emerald-500 font-bold">•</span>
                <span>B2B SaaS companies, tech founders, and scaling high-ticket digital service firms.</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-emerald-500 font-bold">•</span>
                <span>Brands modernizing their web stack to capture non-brand intent across Google, ChatGPT, and Perplexity.</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-emerald-500 font-bold">•</span>
                <span>Companies seeking measurable revenue ROI instead of superficial retainer deliverables.</span>
              </li>
            </ul>
          </div>

          <div class="p-6 rounded-2xl bg-slate-50 dark:bg-slate-900/40 border border-slate-200 dark:border-slate-800">
            <h3 class="text-lg font-bold text-slate-900 dark:text-slate-300 flex items-center gap-2 mb-3">
              <span>✕ Not Designed For:</span>
            </h3>
            <ul class="space-y-2.5 text-xs text-slate-500 dark:text-slate-400">
              <li class="flex items-start gap-2">
                <span class="text-slate-400 font-bold">•</span>
                <span>Low-budget, quick-fix web template setups or basic brochure sites.</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-slate-400 font-bold">•</span>
                <span>Unfocused social media content churning without clear pipeline attribution.</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-slate-400 font-bold">•</span>
                <span>Traditional agencies looking for cheap white-label tactical churn.</span>
              </li>
            </ul>
          </div>

        </div>
      </section>

      <!-- CORPORATE INVOICING & TRUST STRIP -->
      <section class="py-8 bg-blue-50/50 dark:bg-blue-950/30 rounded-2xl p-6 border border-blue-200/60 dark:border-blue-900/50 my-8">
        <div class="flex flex-col md:flex-row items-center justify-between gap-6">
          <div>
            <span class="text-xs font-mono text-blue-600 dark:text-blue-400 uppercase tracking-wider block font-bold">// Agency Backing & Commercial Billing</span>
            <h3 class="text-lg font-bold text-slate-900 dark:text-white mt-0.5">Seamless Corporate Contracting</h3>
            <p class="text-xs text-slate-600 dark:text-slate-300 mt-1 max-w-xl leading-relaxed">
