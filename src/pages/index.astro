---
import BaseLayout from '../layouts/BaseLayout.astro';

const offsiteSchema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "Offsite Thailand",
  "url": "https://psavage.net",
  "image": "https://psavage.net/images/offsite.jpg",
  "description": "Bespoke corporate offsites and team retreats in Chiang Mai and across Thailand for remote software teams.",
  "provider": {
    "@type": "Organization",
    "name": "Ace Marketing Solutions",
    "url": "https://acemsthailand.com"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Chiang Mai",
    "addressCountry": "TH"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "18.7883",
    "longitude": "98.9853"
  },
  "areaServed": ["Chiang Mai", "Phuket", "Bangkok", "Koh Samui", "Thailand"],
  "priceRange": "$$$",
  "sameAs": [
    "https://offsitethailand.com",
    "https://acemsthailand.com",
    "https://x.com/savphill",
    "https://th.linkedin.com/in/phill-savage"
  ]
};
---

<BaseLayout 
  title="Corporate Retreats & Team Offsites in Thailand | Phill Savage"
  description="End-to-end corporate retreats and remote team offsites in Chiang Mai and across Thailand. Client Director at Ace Marketing Solutions, planning via Offsite Thailand."
  keywords={[
    "Corporate Retreats Thailand", 
    "Corporate Offsites Thailand", 
    "Company Retreats Thailand", 
    "Chiang Mai Offsite", 
    "Tech Team Retreats Chiang Mai", 
    "Offsite Thailand"
  ]}
  schema={offsiteSchema}
>
  <!-- STICKY FLOATING CTA (Bottom Right) -->
  <div class="fixed bottom-6 right-6 z-50">
    <a 
      href="#offsite-inquiry" 
      class="flex items-center gap-2.5 px-4 py-3 rounded-full bg-blue-600 hover:bg-blue-500 text-white font-mono text-xs font-bold uppercase tracking-wider shadow-2xl transition-all transform hover:scale-105 border border-blue-400/40 backdrop-blur-md group"
    >
      <span class="relative flex h-2.5 w-2.5">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-cyan-300 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-cyan-400"></span>
      </span>
      <span>Request Proposal</span>
      <span class="group-hover:translate-x-0.5 transition-transform">→</span>
    </a>
  </div>

  <div class="relative overflow-hidden">
    <!-- Ambient Lighting FX -->
    <div class="absolute -top-40 -left-40 w-96 h-96 bg-blue-500/10 dark:bg-blue-600/15 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute top-1/3 -right-40 w-96 h-96 bg-cyan-500/10 dark:bg-cyan-500/15 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute bottom-1/4 -left-40 w-96 h-96 bg-teal-500/10 dark:bg-teal-500/15 rounded-full blur-3xl pointer-events-none"></div>

    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      
      <!-- HERO SECTION -->
      <section class="pt-6 pb-12 md:pt-10 md:pb-16" transition:animate="fade">
        
        <!-- Chiang Mai Clock & Availability Banner -->
        <div class="flex flex-wrap items-center gap-3 mb-8">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-slate-100 dark:bg-slate-800/90 border border-slate-200 dark:border-slate-700/60 text-xs font-mono text-slate-700 dark:text-slate-300 backdrop-blur-sm">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
            </span>
            <span>Chiang Mai: <strong id="live-time" class="text-slate-900 dark:text-white font-semibold">--:-- ICT</strong></span>
          </div>

          <div class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-blue-50 dark:bg-blue-950/50 border border-blue-200/80 dark:border-blue-800/60 text-xs font-mono text-blue-700 dark:text-blue-300">
            <span>⚡ Booking Q4 2026 & Q1 2027 Briefs</span>
          </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-start">
          
          
          <!-- Left Column: Identity & Value Proposition -->
          <div class="lg:col-span-7 text-left space-y-6">
            
            <!-- Profile Identity Card -->
            <div class="flex items-center gap-4 p-3.5 rounded-2xl bg-slate-50 dark:bg-slate-900/40 border border-slate-200/60 dark:border-slate-800/60">
              <img 
                src="/images/phill.jpg" 
                alt="Phill Savage — Client Director at Ace Marketing Solutions" 
                width="96"
                height="96"
                class="w-20 h-20 sm:w-24 sm:h-24 rounded-2xl object-cover ring-2 ring-blue-500/40 shadow-xl flex-shrink-0"
              />
              <div>
                <span class="text-[11px] font-mono uppercase tracking-widest text-blue-600 dark:text-blue-400 font-bold block">// Client Director</span>
                <h2 class="text-xl sm:text-2xl font-black text-slate-900 dark:text-white">Phill Savage</h2>
                <p class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">
                  Ace Marketing Solutions • Offsite Thailand
                </p>
                <div class="flex items-center gap-2 mt-2">
                  <span class="inline-block w-2 h-2 rounded-full bg-emerald-500"></span>
                  <span class="text-[10px] font-mono text-slate-600 dark:text-slate-400">Direct Contact • ~2hr Response</span>
                </div>
              </div>
            </div>

            <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black tracking-tight text-slate-900 dark:text-white leading-[1.1]">
              Corporate Retreats <br class="hidden sm:inline" />
              <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 via-cyan-500 to-teal-400 dark:from-blue-400 dark:via-cyan-300 dark:to-teal-300">
                & Team Offsites
              </span> <br />
              in Thailand.
            </h1>
            
            <p class="text-lg md:text-xl font-normal text-slate-600 dark:text-slate-300 leading-relaxed">
              I consult on high-impact corporate offsites and company retreats for remote software teams across Thailand. Backed by <a href="https://acemsthailand.com" target="_blank" rel="noopener noreferrer" class="underline hover:text-blue-600 font-semibold">Ace Marketing Solutions</a>
            </p>

            <div class="flex flex-wrap gap-2 pt-2">
              <span class="text-xs font-mono px-2.5 py-1 rounded-md bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 border border-slate-200 dark:border-slate-700/50">
                📍 Chiang Mai HQ
              </span>
              <span class="text-xs font-mono px-2.5 py-1 rounded-md bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 border border-slate-200 dark:border-slate-700/50">
                🏝️ Islands & Phuket
              </span>
              <span class="text-xs font-mono px-2.5 py-1 rounded-md bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 border border-slate-200 dark:border-slate-700/50">
                🚀 Remote Tech Teams
              </span>
            </div>
        

          </div>

          <!-- Right Column: Proposal Lead Form + Fail-Safe Contact -->
          <div id="offsite-inquiry" class="lg:col-span-5 relative scroll-mt-12">
            <div class="absolute -inset-1 bg-gradient-to-r from-blue-600 to-cyan-500 rounded-3xl blur opacity-25 dark:opacity-40 transition duration-1000"></div>
            
            <div class="relative bg-white/95 dark:bg-slate-900/95 backdrop-blur-xl p-6 sm:p-7 rounded-2xl border border-slate-200/80 dark:border-slate-800 shadow-2xl">
              <div class="mb-4">
                <div class="flex items-center justify-between">
                  <h2 class="text-xl font-extrabold text-slate-900 dark:text-white">
                    Plan Your Offsite
                  </h2>
                  <span class="text-[10px] font-mono px-2 py-0.5 rounded bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 border border-emerald-500/20 font-bold">
                    Active
                  </span>
                </div>
                <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">
                  Custom proposals built around your team size and target dates.
                </p>
              </div>
              <form 
                name="offsite-inquiry" 
                method="POST" 
                data-netlify="true" 
                netlify-honeypot="bot-field"
                class="space-y-3.5"
              >
                <input type="hidden" name="form-name" value="offsite-inquiry" />
                <p class="hidden"><label><input name="bot-field" /></label></p>

                <div>
                  <label for="name" class="block text-[10px] font-mono uppercase tracking-wider text-slate-500 dark:text-slate-400 mb-1">Your Name</label>
                  <input 
                    type="text" 
                    id="name" 
                    name="name" 
                    required 
                    placeholder="Jane Doe" 
                    class="w-full px-3.5 py-2 text-sm bg-slate-50 dark:bg-slate-950/80 border border-slate-200 dark:border-slate-800 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 text-slate-900 dark:text-white transition-all"
                  />
                </div>

                <div>
                  <label for="email" class="block text-[10px] font-mono uppercase tracking-wider text-slate-500 dark:text-slate-400 mb-1">Work Email</label>
                  <input 
                    type="email" 
                    id="email" 
                    name="email" 
                    required 
                    placeholder="jane@company.com" 
                    class="w-full px-3.5 py-2 text-sm bg-slate-50 dark:bg-slate-950/80 border border-slate-200 dark:border-slate-800 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 text-slate-900 dark:text-white transition-all"
                  />
                </div>

                <div class="grid grid-cols-2 gap-3">
                  <div>
                    <label for="team-size" class="block text-[10px] font-mono uppercase tracking-wider text-slate-500 dark:text-slate-400 mb-1">Team Size</label>
                    <input 
                      type="text" 
                      id="team-size" 
                      name="team-size" 
                      placeholder="e.g. 15-30" 
                      class="w-full px-3.5 py-2 text-sm bg-slate-50 dark:bg-slate-950/80 border border-slate-200 dark:border-slate-800 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 text-slate-900 dark:text-white transition-all"
                    />
                  </div>
                  <div>
                    <label for="preferred-location" class="block text-[10px] font-mono uppercase tracking-wider text-slate-500 dark:text-slate-400 mb-1">Location</label>
                    <input 
                      type="text" 
                      id="preferred-location" 
                      name="preferred-location" 
                      placeholder="Chiang Mai / Phuket" 
                      class="w-full px-3.5 py-2 text-sm bg-slate-50 dark:bg-slate-950/80 border border-slate-200 dark:border-slate-800 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 text-slate-900 dark:text-white transition-all"
                    />
                  </div>
                </div>

                <div>
                  <label for="message" class="block text-[10px] font-mono uppercase tracking-wider text-slate-500 dark:text-slate-400 mb-1">Retreat Details / Goals</label>
                  <textarea 
                    id="message" 
                    name="message" 
                    rows="3" 
                    placeholder="Target dates, specific requirements, or work vs. leisure split..." 
                    class="w-full px-3.5 py-2 text-sm bg-slate-50 dark:bg-slate-950/80 border border-slate-200 dark:border-slate-800 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 text-slate-900 dark:text-white transition-all resize-none"
                  ></textarea>
                </div>

                <button 
                  type="submit" 
                  class="w-full py-3.5 px-4 text-xs font-bold uppercase tracking-wider text-white bg-gradient-to-r from-blue-600 to-cyan-600 hover:from-blue-500 hover:to-cyan-500 rounded-lg shadow-lg shadow-blue-500/25 transition-all transform active:scale-[0.98] mt-1 cursor-pointer"
                >
                  Request Offsite Proposal →
                </button>
              </form>

              <!-- FAIL-SAFE ALTERNATIVE CONTACT -->
              <div class="mt-4 pt-3 border-t border-slate-200/80 dark:border-slate-800/80 text-center">
                <p class="text-[11px] text-slate-500 dark:text-slate-400">
                  Prefer direct channel messaging?
                </p>
                <div class="flex items-center justify-center gap-3 mt-1.5 text-xs font-mono font-medium">
                  <a 
                    href="https://th.linkedin.com/in/phill-savage" 
                    target="_blank" 
                    rel="noopener noreferrer" 
                    class="text-blue-600 dark:text-blue-400 hover:underline flex items-center gap-1"
                  >
                    <span>LinkedIn Direct</span>
                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                  </a>
                  <span class="text-slate-300 dark:text-slate-700">•</span>
                  <a 
                    href="https://x.com/savphill" 
                    target="_blank" 
                    rel="noopener noreferrer" 
                    class="text-blue-600 dark:text-blue-400 hover:underline flex items-center gap-1"
                  >
                    <span>X / Twitter</span>
                  </a>
                </div>
              </div>

            </div>
          </div>

        </div>
      </section>

      <!-- PROOF & METRICS STRIP -->
      <section class="py-6 border-y border-slate-200/60 dark:border-slate-800/60 my-6">
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 text-center">
          <div>
            <div class="text-2xl font-black text-slate-900 dark:text-white font-mono">100%</div>
            <div class="text-xs text-slate-500 dark:text-slate-400 font-medium">Gigabit Fiber Vetted</div>
          </div>
          <div>
            <div class="text-2xl font-black text-slate-900 dark:text-white font-mono">Chiang Mai</div>
            <div class="text-xs text-slate-500 dark:text-slate-400 font-medium">Primary Operations HQ</div>
          </div>
          <div>
            <div class="text-2xl font-black text-slate-900 dark:text-white font-mono">Ace MS</div>
            <div class="text-xs text-slate-500 dark:text-slate-400 font-medium">Agency Account Management</div>
          </div>
          <div>
            <div class="text-2xl font-black text-slate-900 dark:text-white font-mono">0%</div>
            <div class="text-xs text-slate-500 dark:text-slate-400 font-medium">Corporate Cringe</div>
          </div>
        </div>
      </section>

      <!-- FEATURED SHOWCASE -->
      <section class="py-8" transition:animate="fade">
        <div class="relative overflow-hidden rounded-3xl border border-slate-200 dark:border-slate-800 shadow-2xl group">
          <img 
            src="/images/offsite.jpg" 
            alt="Corporate Retreats & Offsites in Thailand" 
            width="1200"
            height="400"
            loading="eager"
            fetchpriority="high"
            class="w-full h-72 sm:h-96 object-cover object-center transform transition-transform duration-700 group-hover:scale-105"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/40 to-transparent flex flex-col justify-end p-6 sm:p-10">
            <div class="flex items-center gap-2 mb-2">
              <span class="px-2.5 py-1 rounded-full bg-cyan-500/20 backdrop-blur-md border border-cyan-400/30 text-cyan-300 text-xs font-mono">
                // Experiential Retreats
              </span>
              <span class="px-2.5 py-1 rounded-full bg-white/10 backdrop-blur-md text-white text-xs font-mono">
                Chiang Mai • Phuket • Bangkok
              </span>
            </div>
            <h3 class="text-xl sm:text-3xl font-extrabold text-white tracking-tight">
              Strategic roadmapping in the mountains, team bonding on the water.
            </h3>
            <p class="text-sm sm:text-base text-slate-300 mt-2 max-w-2xl leading-relaxed">
              We replace awkward corporate team building with authentic Thai experiences. From high-tech mountain workspaces in Chiang Mai to private island catamaran charters, we design offsites your team will talk about for years.
            </p>
          </div>
        </div>
      </section>

      <!-- NEW SECTION 1: THE 3-STEP OFFSITE BLUEPRINT -->
      <section class="py-12 border-t border-slate-200/60 dark:border-slate-800/60" transition:animate="fade">
        <div class="mb-10 text-left">
          <span class="text-xs font-mono uppercase tracking-widest text-blue-600 dark:text-blue-400 font-bold">// How It Works</span>
          <h2 class="text-3xl font-extrabold text-slate-900 dark:text-white mt-1">
            Zero-friction planning in 3 simple steps
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="p-6 rounded-2xl bg-slate-50 dark:bg-slate-900/40 border border-slate-200/80 dark:border-slate-800">
            <div class="text-xs font-mono font-bold text-blue-600 dark:text-blue-400 uppercase tracking-widest mb-2">Step 01</div>
            <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-2">15-Minute Alignment Brief</h3>
            <p class="text-xs text-slate-600 dark:text-slate-400 leading-relaxed">
              Share your team size, preferred dates, and primary goals (e.g., deep product sprints vs. culture celebration).
            </p>
          </div>

          <div class="p-6 rounded-2xl bg-slate-50 dark:bg-slate-900/40 border border-slate-200/80 dark:border-slate-800">
            <div class="text-xs font-mono font-bold text-blue-600 dark:text-blue-400 uppercase tracking-widest mb-2">Step 02</div>
            <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-2">Custom Proposal (48 Hours)</h3>
            <p class="text-xs text-slate-600 dark:text-slate-400 leading-relaxed">
              Receive fully itemized villa/resort options, speed-tested fiber specs, and custom itinerary options ready for leadership sign-off.
            </p>
          </div>

          <div class="p-6 rounded-2xl bg-slate-50 dark:bg-slate-900/40 border border-slate-200/80 dark:border-slate-800">
            <div class="text-xs font-mono font-bold text-blue-600 dark:text-blue-400 uppercase tracking-widest mb-2">Step 03</div>
            <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-2">Managed Ground Execution</h3>
            <p class="text-xs text-slate-600 dark:text-slate-400 leading-relaxed">
              Using approved travel agencies and hotel partners, we ensure all activities, transport and needs are managed.
            </p>
          </div>
        </div>
      </section>

      <!-- NEW SECTION 2: LOCATION SELECTOR MATRIX -->
      <section class="py-12 border-t border-slate-200/60 dark:border-slate-800/60" transition:animate="fade">
        <div class="mb-10 text-left">
          <span class="text-xs font-mono uppercase tracking-widest text-blue-600 dark:text-blue-400 font-bold">// Target Destinations</span>
          <h2 class="text-3xl font-extrabold text-slate-900 dark:text-white mt-1">
            Where should your team land?
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          
          <!-- Chiang Mai -->
          <div class="p-6 rounded-2xl bg-slate-50 dark:bg-slate-900/60 border border-slate-200/80 dark:border-slate-800 flex flex-col justify-between">
            <div>
              <span class="text-[10px] font-mono px-2 py-0.5 rounded bg-blue-500/10 text-blue-600 dark:text-blue-400 font-bold uppercase">Primary HQ</span>
              <h3 class="text-xl font-bold text-slate-900 dark:text-white mt-3 mb-1">Chiang Mai</h3>
              <p class="text-xs font-mono text-slate-500 mb-3">Mountain Sanctuaries • Tech Infrastructure</p>
              <p class="text-xs text-slate-600 dark:text-slate-400 leading-relaxed mb-4">
                Ideal for engineering roadmapping and strategy sprints. High-speed internet, cooler mountain weather, world-class cafe culture, and private mountain villas.
              </p>
            </div>
            <div class="text-[11px] font-mono text-slate-500 dark:text-slate-400 border-t border-slate-200 dark:border-slate-800 pt-3">
              ⚡ <strong>Best for:</strong> Product & Engineering Teams
            </div>
          </div>

          <!-- Phuket -->
          <div class="p-6 rounded-2xl bg-slate-50 dark:bg-slate-900/60 border border-slate-200/80 dark:border-slate-800 flex flex-col justify-between">
            <div>
              <span class="text-[10px] font-mono px-2 py-0.5 rounded bg-cyan-500/10 text-cyan-600 dark:text-cyan-400 font-bold uppercase">Islands</span>
              <h3 class="text-xl font-bold text-slate-900 dark:text-white mt-3 mb-1">Phuket & Andaman</h3>
              <p class="text-xs font-mono text-slate-500 mb-3">Oceanfront Villas • Private Charters</p>
              <p class="text-xs text-slate-600 dark:text-slate-400 leading-relaxed mb-4">
                Designed for milestone celebrations and team bonding. Private luxury beachfront compounds, island hopping, and sunset catamaran dinners.
              </p>
            </div>
            <div class="text-[11px] font-mono text-slate-500 dark:text-slate-400 border-t border-slate-200 dark:border-slate-800 pt-3">
              🏝️ <strong>Best for:</strong> Annual Alignment & Rewards
            </div>
          </div>

          <!-- Bangkok -->
          <div class="p-6 rounded-2xl bg-slate-50 dark:bg-slate-900/60 border border-slate-200/80 dark:border-slate-800 flex flex-col justify-between">
            <div>
              <span class="text-[10px] font-mono px-2 py-0.5 rounded bg-teal-500/10 text-teal-600 dark:text-teal-400 font-bold uppercase">Metropolis</span>
              <h3 class="text-xl font-bold text-slate-900 dark:text-white mt-3 mb-1">Bangkok</h3>
              <p class="text-xs font-mono text-slate-500 mb-3">Urban Luxury • Global Flight Hub</p>
              <p class="text-xs text-slate-600 dark:text-slate-400 leading-relaxed mb-4">
                Maximum convenience for cross-continental teams. High-rise executive boardrooms, Michelin-starred dining, and seamless international transit.
              </p>
            </div>
            <div class="text-[11px] font-mono text-slate-500 dark:text-slate-400 border-t border-slate-200 dark:border-slate-800 pt-3">
              🏙️ <strong>Best for:</strong> Global Executive Leadership
            </div>
          </div>

        </div>
      </section>

      <!-- NEW SECTION 3: INTERACTIVE 5-DAY SAMPLE ITINERARY preview -->
      <section class="py-12 border-t border-slate-200/60 dark:border-slate-800/60" transition:animate="fade">
        <div class="mb-8 text-left">
          <span class="text-xs font-mono uppercase tracking-widest text-blue-600 dark:text-blue-400 font-bold">// Balanced Flow</span>
          <h2 class="text-3xl font-extrabold text-slate-900 dark:text-white mt-1">
            Sample 5-Day Retreat Itinerary
          </h2>
          <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">
            Engineered to prevent zoom fatigue while building real social connection.
          </p>
        </div>

        <div class="space-y-3">
          <div class="p-4 rounded-xl bg-slate-50 dark:bg-slate-900/40 border border-slate-200/80 dark:border-slate-800 flex flex-col sm:flex-row sm:items-center justify-between gap-3">
            <div class="flex items-center gap-3">
