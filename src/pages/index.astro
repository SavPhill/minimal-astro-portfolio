---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostList from '../components/PostList.astro';
import { getCollection } from 'astro:content';
import { SITE, SOCIAL_LINKS } from '../config/site';

const allPosts = await getCollection('posts');
const sortedPosts = allPosts.sort(
  (a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf()
);

const posts = sortedPosts.slice(0, 5).map((post) => ({
  ...post,
  url: `/posts/${post.id}`,
  frontmatter: post.data,
}));
---

<BaseLayout title={SITE.headline} description={SITE.description} pageTitle={SITE.headline}>
  <div class="max-w-4xl mx-auto">
    <section class="text-center py-[8vh]" transition:animate="fade">
      <h1 class="text-4xl md:text-6xl mb-8 font-bold leading-tight">{SITE.headline}</h1>
      <p class="text-lg md:text-xl text-muted-foreground max-w-3xl mx-auto mb-10 leading-relaxed">
        {SITE.description}
      </p>
      {
        SOCIAL_LINKS.length > 0 && (
          <div class="flex flex-wrap justify-center gap-4 text-sm">
            {SOCIAL_LINKS.map(({ platform, url }) => (
              <a
                href={url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 hover:underline"
              >
                {platform}
              </a>
            ))}
          </div>
        )
      }
    </section>

    {
      posts.length > 0 && (
        <section class="mx-auto" transition:animate="fade">
          <h2 class="text-sm uppercase tracking-wide text-gray-500 dark:text-gray-500 mb-8 text-center">
            Writing
          </h2>
          <PostList
            posts={posts}
            showImages={false}
            showExcerpt={false}
            showSeparators={true}
            showTags={false}
          />

          <div class="text-center mt-24">
            <a
              href="/journal"
              class="text-lg font-medium text-black dark:text-white py-2 px-4 rounded-md inline-block focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 hover:underline"
            >
              View all posts <span aria-hidden="true">→</span>
            </a>
          </div>
        </section>
      )
    }
  </div>
</BaseLayout>
