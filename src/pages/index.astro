---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostList from '../components/PostList.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts');
const sortedPosts = allPosts.sort((a, b) => {
  return new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf();
});

const posts = sortedPosts.slice(0, 5).map(post => ({
  ...post,
  url: `/posts/${post.id}`, 
  frontmatter: post.data
}));
---

<BaseLayout title="Phill | Generative Search Architect & AI Systems">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <section class="pt-8 pb-16 md:pt-14 md:pb-20 text-left" transition:animate="fade">
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-black tracking-tight text-slate-900 dark:text-white leading-[1.1] mb-6">
        Position your business to be <br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-cyan-500 dark:from-blue-400 dark:to-cyan-300">
          recommended by AI.
        </span>
      </h1>
      
      <p class="text-xl md:text-2xl font-medium text-slate-700 dark:text-slate-200 max-w-2xl mb-12">
        I’m Phill. By day, I audit codebases so brands get found by AI. The rest of the time, I design offsites for remote software teams.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12 border-t border-slate-100 dark:border-slate-800/60 pt-8">
        <div>
          <div class="text-xs font-mono uppercase tracking-wider text-blue-600 dark:text-blue-400 mb-1">// Expertise</div>
          <div class="text-base font-bold text-slate-900 dark:text-white">10+ Years in Website Consultancy</div>
          <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">Crafting high-performance digital experiences for ultra-luxury resorts and global hotel networks.</p>
        </div>
        
        
        <div>
          <div class="text-xs font-mono uppercase tracking-wider text-blue-600 dark:text-blue-400 mb-1">// Security Core</div>
          <div class="text-base font-bold text-slate-900 dark:text-white">WordPress Contributor</div>
          <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">60+ security contributions to the WordPress ecosystem, including WordPress core.</p>
        </div>

        <div>
          <div class="text-xs font-mono uppercase tracking-wider text-blue-600 dark:text-blue-400 mb-1">// Corporate Retreat Organizer</div>
          <div class="text-base font-bold text-slate-900 dark:text-white">Offsite Thailand</div>
          <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">
            Designing retreats for remote tech companies at <a href="https://offsitethailand.com" class="underline hover:text-blue-500 font-semibold" target="_blank" rel="noopener noreferrer">offsitethailand.com</a> 
          </p>
        </div>
      
      <div>
        <a 
          href="mailto:hello@psavage.net?subject=AI%20Visibility%20Audit%20Request" 
          class="inline-flex items-center justify-center px-5 py-3 text-sm font-bold text-white transition-colors bg-blue-600 rounded-md hover:bg-blue-700 dark:bg-white dark:text-slate-900 dark:hover:bg-gray-100"
        >
          Get Your AI Visibility Audit
        </a>
      </div>
    </section>

    <section class="py-12 border-t border-slate-100 dark:border-slate-800/60" transition:animate="fade">
      <h2 class="text-xs uppercase tracking-widest font-mono text-slate-400 dark:text-slate-500 mb-8">
        // AI Search Optimization
      </h2>
    
      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-8">
        <div class="space-y-1">
          <h3 class="text-sm font-bold uppercase tracking-wider text-slate-900 dark:text-white">Generative Engine Optimization (GEO)</h3>
          <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">
            Technical teardowns analyzing exactly how LLMs track and rank your brand. I map out entity errors and content positioning gaps that cause engines to skip your data.
          </p>
        </div>
    
        <div class="space-y-1">
          <h3 class="text-sm font-bold uppercase tracking-wider text-slate-900 dark:text-white">Answer Engine Optimization (AEO)</h3>
          <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">
            Restructuring legacy layouts into high-signal information blocks. Engineered specifically to secure direct user recommendations and text citations inside ChatGPT, Perplexity, and Gemini.
          </p>
        </div>
    
        <div class="space-y-1">
          <h3 class="text-sm font-bold uppercase tracking-wider text-slate-900 dark:text-white">Entity Graph Mapping</h3>
          <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">
            Deploying nested JSON-LD data clusters and relational schemas. This gives machine retrieval models a verified, unshakeable blueprint of your business info so they quote you without hallucinating.
          </p>
        </div>
    
        <div class="space-y-1">
          <h3 class="text-sm font-bold uppercase tracking-wider text-slate-900 dark:text-white">Crawler Pipeline Architecture</h3>
          <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">
            Migrating heavy sites over to clean, static environments like Astro. Flat-file frameworks optimized for the fast-evolving agentic bots and scrapers rewriting the rules of modern web indexing.
          </p>
        </div>
      </div>
    </section>

    <section class="py-12 border-t border-slate-100 dark:border-slate-800/60" transition:animate="fade">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-xs uppercase tracking-widest font-mono text-slate-400 dark:text-slate-500">
          // Latest Search Intelligence
        </h2>
        <a href="/journal" class="text-xs font-bold text-blue-600 dark:text-blue-400 hover:underline">
          View all insights →
        </a>
      </div>
      
      <PostList 
        posts={posts} 
        showImages={false} 
        showExcerpt={true} 
        showSeparators={true} 
        showTags={true}
      />
    </section>

  </div>
</BaseLayout>