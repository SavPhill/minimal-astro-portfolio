---
import BaseLayout from '../layouts/BaseLayout.astro';
import cveData from '../data/cves.json';
---

<BaseLayout title="Security Research | CVEs">
  <div class="max-w-4xl mx-auto">
    <h1 class="text-5xl font-bold mb-8">Security Research</h1>
    <div class="prose prose-lg dark:prose-invert max-w-none leading-relaxed" transition:animate="fade">
      <p>
        I've made quite a few contribution to open source projects and have been actively involved in security research, especially within the WordPress ecosystem.</p>
    
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="border-b border-slate-200 dark:border-slate-800">
            <th class="py-4 font-bold">Software / Vulnerability</th>
            <th class="py-4 font-bold text-center">CVE ID</th>
            <th class="py-4 font-bold text-center">CVSS</th>
            <th class="py-4 font-bold text-right">Disclosure</th>
          </tr>
        </thead>
        <tbody>
          {cveData.map((cve) => (
            <tr class={`border-b border-slate-100 dark:border-slate-900 transition hover:bg-slate-50 dark:hover:bg-slate-800 ${cve.featured ? 'bg-blue-50/40 dark:bg-blue-900/10' : ''}`}>
              <td class="py-4 pr-4">
                <a href={cve.url} target="_blank" class="text-blue-600 no-underline hover:underline font-medium">
                  {cve.title}
                </a>
              </td>
              <td class="py-4 text-center font-mono text-xs">
                <a href={cve.cveUrl} target="_blank" class="text-muted-foreground hover:text-blue-600">
                  {cve.cveId}
                </a>
              </td>
              <td class="py-4 text-center">
                <span class={`px-2 py-1 rounded text-xs font-bold ${parseFloat(cve.cvss) >= 7 ? 'bg-red-100 text-red-800' : 'bg-slate-100 text-slate-800'}`}>
                  {cve.cvss}
                </span>
              </td>
              <td class="py-4 text-right text-slate-500 text-sm whitespace-nowrap">
                {cve.date}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</BaseLayout>