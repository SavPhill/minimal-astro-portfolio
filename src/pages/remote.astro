---
import BaseLayout from '../layouts/BaseLayout.astro';

const offsiteSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Offsite Thailand — Corporate Retreat Operations",
  "serviceType": "Corporate Event & Team Retreat Planning",
  "provider": {
    "@type": "Organization",
    "name": "Offsite Thailand",
    "url": "https://offsitethailand.com"
  },
  "areaServed": [
    "Chiang Mai",
    "Phuket",
    "Bangkok",
    "Hua Hin",
    "Pattaya",
    "Chiang Rai",
    "Thailand"
  ],
  "description": "End-to-end tailored company retreats, executive planning trips, and remote team meetups across Chiang Mai and Thailand."
};
---

<BaseLayout 
  title="Company Retreats & Remote Team Offsites in Chiang Mai & Thailand" 
  description="End-to-end tailored company retreats, executive planning trips, and remote team meetups across Chiang Mai and Thailand. Directed by Phill Savage."
  keywords={["Chiang Mai Retreats", "Thailand Company Offsite", "Remote Team Retreat Thailand", "Tech Offsite Chiang Mai"]}
  schema={offsiteSchema}
>
  <div class="relative overflow-hidden">
    <!-- Ambient Background FX -->
    <div class="absolute -top-40 -left-40 w-96 h-96 bg-blue-500/10 dark:bg-blue-600/15 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute top-1/3 -right-40 w-96 h-96 bg-cyan-500/10 dark:bg-cyan-500/15 rounded-full blur-3xl pointer-events-none"></div>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-20 relative z-10">
      
      <!-- HERO HEADER -->
      <header class="pt-8 md:pt-14 mb-10" transition:animate="fade">
        
        <!-- Live Status Pill -->
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-slate-100 dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 mb-6 backdrop-blur-sm">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
          </span>
          <span class="text-xs font-mono font-medium text-slate-700 dark:text-slate-300">
            Chiang Mai Operations HQ • Accepting 2026/2027 Briefs
          </span>
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl mb-6 font-black tracking-tight text-slate-900 dark:text-white leading-[1.1]">
          Stop micro-managing <br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 via-cyan-500 to-teal-400 dark:from-blue-400 dark:via-cyan-300 dark:to-teal-300">
            your team's retreats.
          </span>
        </h1>
        
        <p class="text-lg md:text-xl text-slate-600 dark:text-slate-300 max-w-2xl leading-relaxed">
          I serve as Project Director for <strong class="text-slate-900 dark:text-white">Offsite Thailand</strong>. Backed by Ace Marketing Solutions and Boutiq Thailand, our team builds end-to-end custom itineraries so distributed software companies can gather in person without the logistical headaches.
        </p>
      </header>

      <!-- HERO IMAGE FEATURE CARD -->
      <div class="mb-10 relative overflow-hidden rounded-3xl border border-slate-200 dark:border-slate-800 shadow-2xl group" transition:animate="fade">
        <img 
          src="/images/offsite.jpg" 
          alt="Offsite Thailand — Team retreat operations on location in Chiang Mai & Thailand" 
          class="w-full h-[300px] sm:h-[400px] md:h-[460px] object-cover object-center transform transition-transform duration-700 group-hover:scale-105"
          loading="eager"
          decoding="async"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-slate-950/90 via-slate-950/30 to-transparent flex flex-col justify-end p-6 sm:p-8">
          <div class="flex items-center gap-2 mb-2">
            <span class="px-2.5 py-1 rounded-full bg-cyan-500/20 backdrop-blur-md border border-cyan-400/30 text-cyan-300 text-xs font-mono">
              // Ground Operations
            </span>
            <span class="px-2.5 py-1 rounded-full bg-white/10 backdrop-blur-md text-white text-xs font-mono">
              Chiang Mai • Phuket • Bangkok
            </span>
          </div>
          <p class="text-base sm:text-lg font-bold text-white">
            End-to-end ground logistics tailored specifically for remote engineering & product teams.
          </p>
        </div>
      </div>

      <!-- PROOF & METRICS STRIP -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 py-6 mb-12 border-y border-slate-200/60 dark:border-slate-800/60" transition:animate="fade">
        <div>
          <span class="block text-2xl font-black text-slate-900 dark:text-white font-mono">30+ Yrs</span>
          <span class="text-[10px] font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider">Combined Hospitality</span>
        </div>
        <div>
          <span class="block text-2xl font-black text-slate-900 dark:text-white font-mono">100%</span>
          <span class="text-[10px] font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider">Custom Itineraries</span>
        </div>
        <div>
          <span class="block text-2xl font-black text-slate-900 dark:text-white font-mono">Chiang Mai</span>
          <span class="text-[10px] font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider">Primary HQ Node</span>
        </div>
        <div>
          <span class="block text-2xl font-black text-slate-900 dark:text-white font-mono">Zero</span>
          <span class="text-[10px] font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider">Corporate Cringe</span>
        </div>
      </div>

      <!-- PROSE EXPLANATION -->
      <div class="prose prose-lg dark:prose-invert max-w-3xl mb-16 text-slate-700 dark:text-slate-300 leading-relaxed" transition:animate="fade">
        <p>
          Bringing globally distributed teams together shouldn't feel like an administrative nightmare. Most companies waste weeks arguing over hotel choices, diet configurations, airport ground routes, and venue spacing constraints.
        </p>
        <p>
          We built <strong>Offsite Thailand</strong> to run like a clean software deployment. We handle the entire stack manually—sourcing secure local venues in Chiang Mai and island destinations, coordinating regional transit lanes, managing complex allergy requirements, and locking down dedicated fiber-backed meeting infrastructure.
        </p>
        <p>
          This isn't generic event planning. It's high-touch hospitality tailored for tech operators who need to jump straight from strategic product roadmapping to local cultural excursions without missing a beat.
        </p>
      </div>

      <!-- CORE RETREAT TRACKS -->
      <section class="py-12 border-t border-slate-200/60 dark:border-slate-800/60" transition:animate="fade">
        <div class="mb-8">
          <span class="text-xs font-mono uppercase tracking-widest text-blue-600 dark:text-blue-400 font-bold">// Core Retreat Tracks</span>
          <h2 class="text-2xl sm:text-3xl font-extrabold text-slate-900 dark:text-white mt-1">Tailored for every team tier</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="p-6 rounded-2xl bg-slate-50 dark:bg-slate-900/60 border border-slate-200/80 dark:border-slate-800/80 hover:border-blue-500/50 transition-all">
            <span class="text-xs font-mono text-blue-600 dark:text-blue-400 font-bold uppercase tracking-wider block mb-1">// Track 01</span>
            <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-2">Company Retreats</h3>
            <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">
              Full-scale corporate infrastructure setup. We blend team activities, comfortable accommodation layouts, and regional venue logistics for large international scaleups.
            </p>
          </div>

          <div class="p-6 rounded-2xl bg-slate-50 dark:bg-slate-900/60 border border-slate-200/80 dark:border-slate-800/80 hover:border-blue-500/50 transition-all">
            <span class="text-xs font-mono text-blue-600 dark:text-blue-400 font-bold uppercase tracking-wider block mb-1">// Track 02</span>
            <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-2">Executive & Leadership Trips</h3>
            <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">
              High-tier environments designed for heads of engineering and founders. Premium private spacing focused on deep strategic roadmapping, wellness, and isolation.
            </p>
          </div>

          <div class="p-6 rounded-2xl bg-slate-50 dark:bg-slate-900/60 border border-slate-200/80 dark:border-slate-800/80 hover:border-blue-500/50 transition-all">
            <span class="text-xs font-mono text-blue-600 dark:text-blue-400 font-bold uppercase tracking-wider block mb-1">// Track 03</span>
            <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-2">Remote Workforce Meetups</h3>
            <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">
              Bringing asynchronous teams face-to-face for the first time. We design schedules balancing deep work blocks with natural, unforced local connection loops.
            </p>
          </div>

          <div class="p-6 rounded-2xl bg-slate-50 dark:bg-slate-900/60 border border-slate-200/80 dark:border-slate-800/80 hover:border-blue-500/50 transition-all">
            <span class="text-xs font-mono text-blue-600 dark:text-blue-400 font-bold uppercase tracking-wider block mb-1">// Track 04</span>
            <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-2">Team Culture & Adventures</h3>
            <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">
              Private catamaran charters, Muay Thai sessions, mountain hikes, and authentic food tours designed to test team problem-solving without corporate clichés.
            </p>
          </div>
        </div>
      </section>

      <!-- FOOTPRINT NODES GRID -->
      <section class="py-12 border-t border-slate-200/60 dark:border-slate-800/60" transition:animate="fade">
        <div class="mb-8">
          <span class="text-xs font-mono uppercase tracking-widest text-blue-600 dark:text-blue-400 font-bold">// Footprint Nodes</span>
          <h2 class="text-2xl sm:text-3xl font-extrabold text-slate-900 dark:text-white mt-1">Native Thailand Networks</h2>
          <p class="text-sm text-slate-600 dark:text-slate-400 mt-1 max-w-xl">
            We source and execute ground programs natively across Thailand’s most stable infrastructure centers.
          </p>
        </div>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4 text-sm font-mono">
          <div class="p-4 rounded-xl bg-slate-50 dark:bg-slate-900/40 border border-slate-200/80 dark:border-slate-800">
            <div class="font-bold text-slate-900 dark:text-white flex items-center gap-1.5">
              <span>📍 Chiang Mai</span>
              <span class="text-[10px] bg-blue-500/10 text-blue-600 dark:text-blue-400 px-1.5 py-0.5 rounded font-bold">Flagship</span>
            </div>
            <span class="text-slate-500 dark:text-slate-400 text-xs block mt-1">// Mountain Workspaces & Tech Hub</span>
          </div>

          <div class="p-4 rounded-xl bg-slate-50 dark:bg-slate-900/40 border border-slate-200/80 dark:border-slate-800">
            <div class="font-bold text-slate-900 dark:text-white">📍 Phuket</div>
            <span class="text-slate-500 dark:text-slate-400 text-xs block mt-1">// Coastal Islands & Private Catamarans</span>
          </div>

          <div class="p-4 rounded-xl bg-slate-50 dark:bg-slate-900/40 border border-slate-200/80 dark:border-slate-800">
            <div class="font-bold text-slate-900 dark:text-white">📍 Bangkok</div>
            <span class="text-slate-500 dark:text-slate-400 text-xs block mt-1">// Urban HQ & Transit Connectivity</span>
          </div>

          <div class="p-4 rounded-xl bg-slate-50 dark:bg-slate-900/40 border border-slate-200/80 dark:border-slate-800">
            <div class="font-bold text-slate-900 dark:text-white">📍 Hua Hin</div>
            <span class="text-slate-500 dark:text-slate-400 text-xs block mt-1">// Quiet Coastal Executive Enclaves</span>
          </div>

          <div class="p-4 rounded-xl bg-slate-50 dark:bg-slate-900/40 border border-slate-200/80 dark:border-slate-800">
            <div class="font-bold text-slate-900 dark:text-white">📍 Pattaya</div>
            <span class="text-slate-500 dark:text-slate-400 text-xs block mt-1">// Beachfront Access & High Accessibility</span>
          </div>

          <div class="p-4 rounded-xl bg-slate-50 dark:bg-slate-900/40 border border-slate-200/80 dark:border-slate-800">
            <div class="font-bold text-slate-900 dark:text-white">📍 Chiang Rai</div>
            <span class="text-slate-500 dark:text-slate-400 text-xs block mt-1">// Deep Isolation & Nature Sprints</span>
          </div>
        </div>
      </section>

      <!-- DELIVERY PIPELINE STEPPER -->
      <section class="py-12 border-t border-slate-200/60 dark:border-slate-800/60" transition:animate="fade">
        <div class="mb-8">
          <span class="text-xs font-mono uppercase tracking-widest text-blue-600 dark:text-blue-400 font-bold">// Delivery Pipeline</span>
          <h2 class="text-2xl sm:text-3xl font-extrabold text-slate-900 dark:text-white mt-1">How we execute your retreat</h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 font-mono text-xs">
          <div class="p-5 rounded-xl bg-slate-50 dark:bg-slate-900/60 border border-slate-200/80 dark:border-slate-800/80">
            <div class="text-blue-600 dark:text-blue-400 font-black text-sm mb-2">01 / SCOPE</div>
            <p class="text-slate-600 dark:text-slate-400 leading-relaxed font-sans text-xs">Briefing call to map out team scale, engineering goals, budget, and cultural pacing.</p>
          </div>

          <div class="p-5 rounded-xl bg-slate-50 dark:bg-slate-900/60 border border-slate-200/80 dark:border-slate-800/80">
            <div class="text-blue-600 dark:text-blue-400 font-black text-sm mb-2">02 / ESTIMATE</div>
            <p class="text-slate-600 dark:text-slate-400 leading-relaxed font-sans text-xs">Comprehensive proposal itemizing accommodation, transit networks, food, and activities.</p>
          </div>

          <div class="p-5 rounded-xl bg-slate-50 dark:bg-slate-900/60 border border-slate-200/80 dark:border-slate-800/80">
            <div class="text-blue-600 dark:text-blue-400 font-black text-sm mb-2">03 / REFINE</div>
            <p class="text-slate-600 dark:text-slate-400 leading-relaxed font-sans text-xs">Lock in resort layers, verify gigabit fiber internet specs, and finalize workshop blocks.</p>
          </div>

          <div class="p-5 rounded-xl bg-slate-50 dark:bg-slate-900/60 border border-slate-200/80 dark:border-slate-800/80">
            <div class="text-blue-600 dark:text-blue-400 font-black text-sm mb-2">04 / DEPLOY</div>
            <p class="text-slate-600 dark:text-slate-400 leading-relaxed font-sans text-xs">Your remote team arrives in Thailand. Our ground operators handle every detail live.</p>
          </div>
        </div>
      </section>

      <!-- CALL TO ACTION CONTAINER -->
      <div class="bg-slate-900 text-white dark:bg-slate-900/90 border border-slate-800 rounded-3xl p-8 sm:p-10 text-left shadow-2xl relative overflow-hidden mt-8" transition:animate="fade">
        <div class="absolute -right-10 -bottom-10 w-48 h-48 bg-blue-500/20 rounded-full blur-2xl pointer-events-none"></div>

        <div class="max-w-2xl">
          <span class="text-xs font-mono uppercase tracking-widest text-cyan-400 block mb-2">// Start Planning</span>
          <h3 class="text-2xl sm:text-3xl font-extrabold text-white mb-3">Ready to brief our operations team?</h3>
          <p class="text-slate-300 text-sm sm:text-base leading-relaxed mb-6">
            Skip standard contact forms. Send over your target dates, group size, and destination preference directly to our planners.
          </p>

          <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-4">
            <a 
              href="https://offsitethailand.com/" 
              target="_blank" 
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center px-6 py-3.5 text-xs font-mono font-bold uppercase tracking-wider text-slate-900 bg-white hover:bg-slate-100 rounded-lg transition-colors text-center shadow-lg"
            >
              Visit OffsiteThailand.com →
            </a>
            <a 
              href="mailto:hello@psavage.net?subject=Thailand%20Retreat%20Briefing" 
              class="inline-flex items-center justify-center px-6 py-3.5 text-xs font-mono font-bold uppercase tracking-wider text-white border border-slate-700 hover:border-slate-500 rounded-lg transition-colors text-center"
            >
              Direct Email Briefing
            </a>
          </div>
        </div>
      </div>

    </div>
  </div>
</BaseLayout>