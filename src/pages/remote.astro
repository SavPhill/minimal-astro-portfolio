---
import BaseLayout from '../layouts/BaseLayout.astro';

const consultingSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Fractional Web Strategy & Growth Consulting",
  "serviceType": "Fractional CMO & Technical Web Advisory",
  "provider": {
    "@type": "Organization",
    "name": "Ace Marketing Solutions",
    "url": "https://acemsthailand.com"
  },
  "areaServed": [
    "Global",
    "United States",
    "Europe",
    "Asia-Pacific",
    "Thailand"
  ],
  "description": "Fractional web strategy, Astro development, modern growth marketing, and Generative Engine Optimization (GEO) for remote software companies and scaling startups."
};
---

<BaseLayout 
  title="Fractional Web Strategy, Astro Dev & GEO Consulting | Phill Savage" 
  description="Fractional web strategy, high-performance Astro development, growth marketing, and Generative Engine Optimization (GEO) consulting for remote tech teams."
  keywords={["Fractional Web Strategist", "Astro Developer Consulting", "Generative Engine Optimization", "GEO Consultant", "Fractional Growth Director", "Remote Tech Advisory"]}
  schema={consultingSchema}
>
  <div class="relative overflow-hidden">
    <!-- Ambient Background FX -->
    <div class="absolute -top-40 -left-40 w-96 h-96 bg-blue-500/10 dark:bg-blue-600/15 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute top-1/3 -right-40 w-96 h-96 bg-cyan-500/10 dark:bg-cyan-500/15 rounded-full blur-3xl pointer-events-none"></div>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-20 relative z-10">
      
      <!-- HERO HEADER -->
      <header class="pt-8 md:pt-14 mb-10" transition:animate="fade">
        
        <!-- Live Status Pill -->
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-slate-100 dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700/60 mb-6 backdrop-blur-sm">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
          </span>
          <span class="text-xs font-mono font-medium text-slate-700 dark:text-slate-300">
            Chiang Mai HQ • Fractional & Advisory Engagements
          </span>
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl mb-6 font-black tracking-tight text-slate-900 dark:text-white leading-[1.1]">
          Embedded strategy for <br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 via-cyan-500 to-teal-400 dark:from-blue-400 dark:via-cyan-300 dark:to-teal-300">
            high-growth digital brands.
          </span>
        </h1>
        
        <p class="text-lg md:text-xl text-slate-600 dark:text-slate-300 max-w-2xl leading-relaxed">
          I serve as a fractional web strategist and growth advisor. Backed by <a href="https://acemsthailand.com" target="_blank" rel="noopener noreferrer" class="underline hover:text-blue-600 font-semibold">Ace Marketing Solutions</a>, I help distributed engineering and marketing teams build modern web architecture, optimize conversions, and lead AI search discovery.
        </p>
      </header>

      <!-- HERO IMAGE FEATURE CARD -->
      <div class="mb-10 relative overflow-hidden rounded-3xl border border-slate-200 dark:border-slate-800 shadow-2xl group" transition:animate="fade">
        <img 
          src="/images/offsite.jpg" 
          alt="Fractional Consulting & Remote Web Strategy" 
          class="w-full h-[300px] sm:h-[400px] md:h-[460px] object-cover object-center transform transition-transform duration-700 group-hover:scale-105"
          loading="eager"
          decoding="async"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-slate-950/90 via-slate-950/30 to-transparent flex flex-col justify-end p-6 sm:p-8">
          <div class="flex items-center gap-2 mb-2">
            <span class="px-2.5 py-1 rounded-full bg-cyan-500/20 backdrop-blur-md border border-cyan-400/30 text-cyan-300 text-xs font-mono">
              // Fractional Advisory
            </span>
            <span class="px-2.5 py-1 rounded-full bg-white/10 backdrop-blur-md text-white text-xs font-mono">
              Web Architecture • GEO • Conversion
            </span>
          </div>
          <p class="text-base sm:text-lg font-bold text-white">
            Senior leadership without full-time overhead. Bridging technical engineering and performance growth.
          </p>
        </div>
      </div>

      <!-- PROOF & METRICS STRIP -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 py-6 mb-12 border-y border-slate-200/60 dark:border-slate-800/60" transition:animate="fade">
        <div>
          <span class="block text-2xl font-black text-slate-900 dark:text-white font-mono">10+ Yrs</span>
          <span class="text-[10px] font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider">Digital Leadership</span>
        </div>
        <div>
          <span class="block text-2xl font-black text-slate-900 dark:text-white font-mono">Astro 5+</span>
          <span class="text-[10px] font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider">Jamstack Performance</span>
        </div>
        <div>
          <span class="block text-2xl font-black text-slate-900 dark:text-white font-mono">GEO First</span>
          <span class="text-[10px] font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider">AI Search Optimization</span>
        </div>
        <div>
          <span class="block text-2xl font-black text-slate-900 dark:text-white font-mono">Ace MS</span>
          <span class="text-[10px] font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider">Agency Backing</span>
        </div>
      </div>

      <!-- PROSE EXPLANATION -->
      <div class="prose prose-lg dark:prose-invert max-w-3xl mb-16 text-slate-700 dark:text-slate-300 leading-relaxed" transition:animate="fade">
        <p>
          Scaling tech companies frequently hit a growth ceiling where marketing lacks technical rigor and engineering lacks acquisition intuition. Full-time executive hires are expensive and slow to onboard, while tactical freelancers often lack senior business context.
        </p>
        <p>
          I offer a targeted **Fractional Strategy & Advisory model**. I embed directly with leadership teams to refactor legacy websites into ultra-fast Jamstack architectures, realign product messaging, and implement Generative Engine Optimization (GEO) strategies to secure brand authority in ChatGPT, Perplexity, and Gemini responses.
        </p>
        <p>
          Backed by the full production and media resources of <strong><a href="https://acemsthailand.com" target="_blank" rel="noopener noreferrer" class="underline hover:text-blue-600">Ace Marketing Solutions</a></strong>, this model delivers senior direction alongside reliable, agency-grade execution.
        </p>
      </div>

      <!-- CORE CONSULTING TRACKS -->
      <section class="py-12 border-t border-slate-200/60 dark:border-slate-800/60" transition:animate="fade">
        <div class="mb-8">
          <span class="text-xs font-mono uppercase tracking-widest text-blue-600 dark:text-blue-400 font-bold">// Core Advisory Tracks</span>
          <h2 class="text-2xl sm:text-3xl font-extrabold text-slate-900 dark:text-white mt-1">Tailored for scaling digital organizations</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="p-6 rounded-2xl bg-slate-50 dark:bg-slate-900/60 border border-slate-200/80 dark:border-slate-800/80 hover:border-blue-500/50 transition-all">
            <span class="text-xs font-mono text-blue-600 dark:text-blue-400 font-bold uppercase tracking-wider block mb-1">// Track 01</span>
            <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-2">Modern Web Strategy & Astro Development</h3>
            <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">
              Migrating bloatware monoliths to light, secure, sub-second Astro architectures. Perfect Core Web Vitals, headless CMS integration, and developer-friendly maintainability.
            </p>
          </div>

          <div class="p-6 rounded-2xl bg-slate-50 dark:bg-slate-900/60 border border-slate-200/80 dark:border-slate-800/80 hover:border-blue-500/50 transition-all">
            <span class="text-xs font-mono text-blue-600 dark:text-blue-400 font-bold uppercase tracking-wider block mb-1">// Track 02</span>
            <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-2">Generative Engine Optimization (GEO)</h3>
            <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">
              Structuring structured schema markup, entity graphs, and authority vectors so your business is recommended, cited, and summarized inside AI discovery engines.
            </p>
          </div>

          <div class="p-6 rounded-2xl bg-slate-50 dark:bg-slate-900/60 border border-slate-200/80 dark:border-slate-800/80 hover:border-blue-500/50 transition-all">
            <span class="text-xs font-mono text-blue-600 dark:text-blue-400 font-bold uppercase tracking-wider block mb-1">// Track 03</span>
            <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-2">Conversion Rate Optimization (CRO)</h3>
            <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">
              Eliminating funnel friction through copy alignment, UX audits, and high-converting landing page frameworks designed to turn traffic into qualified pipeline.
            </p>
          </div>

          <div class="p-6 rounded-2xl bg-slate-50 dark:bg-slate-900/60 border border-slate-200/80 dark:border-slate-800/80 hover:border-blue-500/50 transition-all">
            <span class="text-xs font-mono text-blue-600 dark:text-blue-400 font-bold uppercase tracking-wider block mb-1">// Track 04</span>
            <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-2">Fractional Web & Growth Leadership</h3>
            <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">
              Providing strategic oversight for founders and marketing leads. Leading sprints, vetting technical decisions, and directing multi-channel execution.
            </p>
          </div>
        </div>
      </section>

      <!-- FOOTPRINT NODES GRID -->
      <section class="py-12 border-t border-slate-200/60 dark:border-slate-800/60" transition:animate="fade">
        <div class="mb-8">
          <span class="text-xs font-mono uppercase tracking-widest text-blue-600 dark:text-blue-400 font-bold">// Strategic Focus</span>
          <h2 class="text-2xl sm:text-3xl font-extrabold text-slate-900 dark:text-white mt-1">Core Capability Domains</h2>
          <p class="text-sm text-slate-600 dark:text-slate-400 mt-1 max-w-xl">
            Key areas of impact where fractional advisory accelerates pipeline and web performance.
          </p>
        </div>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4 text-sm font-mono">
          <div class="p-4 rounded-xl bg-slate-50 dark:bg-slate-900/40 border border-slate-200/80 dark:border-slate-800">
            <div class="font-bold text-slate-900 dark:text-white flex items-center gap-1.5">
              <span>🚀 Astro Architecture</span>
              <span class="text-[10px] bg-blue-500/10 text-blue-600 dark:text-blue-400 px-1.5 py-0.5 rounded font-bold">Core</span>
            </div>
            <span class="text-slate-500 dark:text-slate-400 text-xs block mt-1">// Fast, Modern Static Builds</span>
          </div>

          <div class="p-4 rounded-xl bg-slate-50 dark:bg-slate-900/40 border border-slate-200/80 dark:border-slate-800">
            <div class="font-bold text-slate-900 dark:text-white">🤖 GEO Optimization</div>
            <span class="text-slate-500 dark:text-slate-400 text-xs block mt-1">// AI Search Engine Visibility</span>
          </div>

          <div class="p-4 rounded-xl bg-slate-50 dark:bg-slate-900/40 border border-slate-200/80 dark:border-slate-800">
            <div class="font-bold text-slate-900 dark:text-white">🎯 Funnel Architecture</div>
            <span class="text-slate-500 dark:text-slate-400 text-xs block mt-1">// High-Converting B2B Pages</span>
          </div>

          <div class="p-4 rounded-xl bg-slate-50 dark:bg-slate-900/40 border border-slate-200/80 dark:border-slate-800">
            <div class="font-bold text-slate-900 dark:text-white">⚡ Core Web Vitals</div>
            <span class="text-slate-500 dark:text-slate-400 text-xs block mt-1">// Sub-Second Speed Optimization</span>
          </div>

          <div class="p-4 rounded-xl bg-slate-50 dark:bg-slate-900/40 border border-slate-200/80 dark:border-slate-800">
            <div class="font-bold text-slate-900 dark:text-white">🏷️ Schema & Entity Graphs</div>
            <span class="text-slate-500 dark:text-slate-400 text-xs block mt-1">// Semantic Data Modeling</span>
          </div>

          <div class="p-4 rounded-xl bg-slate-50 dark:bg-slate-900/40 border border-slate-200/80 dark:border-slate-800">
            <div class="font-bold text-slate-900 dark:text-white">💼 Fractional Advisory</div>
            <span class="text-slate-500 dark:text-slate-400 text-xs block mt-1">// Executive Web & Growth Leadership</span>
          </div>
        </div>
      </section>

      <!-- DELIVERY PIPELINE STEPPER -->
      <section class="py-12 border-t border-slate-200/60 dark:border-slate-800/60" transition:animate="fade">
        <div class="mb-8">
          <span class="text-xs font-mono uppercase tracking-widest text-blue-600 dark:text-blue-400 font-bold">// Engagement Pipeline</span>
          <h2 class="text-2xl sm:text-3xl font-extrabold text-slate-900 dark:text-white mt-1">How fractional advisory works</h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 font-mono text-xs">
          <div class="p-5 rounded-xl bg-slate-50 dark:bg-slate-900/60 border border-slate-200/80 dark:border-slate-800/80">
            <div class="text-blue-600 dark:text-blue-400 font-black text-sm mb-2">01 / AUDIT</div>
            <p class="text-slate-600 dark:text-slate-400 leading-relaxed font-sans text-xs">Comprehensive review of your site speed, architecture, conversion bottlenecks, and AI search presence.</p>
          </div>

          <div class="p-5 rounded-xl bg-slate-50 dark:bg-slate-900/60 border border-slate-200/80 dark:border-slate-800/80">
            <div class="text-blue-600 dark:text-blue-400 font-black text-sm mb-2">02 / BLUEPRINT</div>
            <p class="text-slate-600 dark:text-slate-400 leading-relaxed font-sans text-xs">Custom roadmap detailing technical refactoring, schema implementation, and messaging realignment.</p>
          </div>

          <div class="p-5 rounded-xl bg-slate-50 dark:bg-slate-900/60 border border-slate-200/80 dark:border-slate-800/80">
            <div class="text-blue-600 dark:text-blue-400 font-black text-sm mb-2">03 / EXECUTE</div>
            <p class="text-slate-600 dark:text-slate-400 leading-relaxed font-sans text-xs">Hands-on leadership sprint to build pages, deploy structured data, and optimize conversion pathways.</p>
          </div>

          <div class="p-5 rounded-xl bg-slate-50 dark:bg-slate-900/60 border border-slate-200/80 dark:border-slate-800/80">
            <div class="text-blue-600 dark:text-blue-400 font-black text-sm mb-2">04 / SCALE</div>
            <p class="text-slate-600 dark:text-slate-400 leading-relaxed font-sans text-xs">Ongoing fractional oversight, monitoring GEO performance, and refining conversion funnel metrics.</p>
          </div>
        </div>
      </section>

      <!-- CALL TO ACTION CONTAINER -->
      <div class="bg-slate-900 text-white dark:bg-slate-900/90 border border-slate-800 rounded-3xl p-8 sm:p-10 text-left shadow-2xl relative overflow-hidden mt-8" transition:animate="fade">
        <div class="absolute -right-10 -bottom-10 w-48 h-48 bg-blue-500/20 rounded-full blur-2xl pointer-events-none"></div>

        <div class="max-w-2xl">
          <span class="text-xs font-mono uppercase tracking-widest text-cyan-400 block mb-2">// Start Engagement</span>
          <h3 class="text-2xl sm:text-3xl font-extrabold text-white mb-3">Ready to optimize your web strategy?</h3>
          <p class="text-slate-300 text-sm sm:text-base leading-relaxed mb-6">
            Let’s discuss your current web stack, AI search strategy, or fractional advisory requirements.
          </p>

          <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-4">
            <a 
              href="mailto:hello@psavage.net?subject=Fractional%20Web%20Strategy%20Inquiry" 
              class="inline-flex items-center justify-center px-6 py-3.5 text-xs font-mono font-bold uppercase tracking-wider text-slate-900 bg-white hover:bg-slate-100 rounded-lg transition-colors text-center shadow-lg"
            >
              Email Phill Directly →
            </a>
            <a 
              href="https://acemsthailand.com" 
              target="_blank" 
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center px-6 py-3.5 text-xs font-mono font-bold uppercase tracking-wider text-white border border-slate-700 hover:border-slate-500 rounded-lg transition-colors text-center"
            >
              Visit Ace Marketing Solutions
            </a>
          </div>
        </div>
      </div>

    </div>
  </div>
</BaseLayout>