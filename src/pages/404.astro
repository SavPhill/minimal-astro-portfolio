---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - Model Hallucination" description="The page you're looking for doesn't exist or a retrieval error has occurred.">
  <div class="flex flex-col items-center justify-center text-center min-h-[80vh] py-16 md:py-24">
    <div class="mb-8 p-4 bg-red-50 dark:bg-red-900/10 rounded-full">
      <h1 class="text-7xl md:text-9xl font-extrabold text-blue-600 mb-0">404</h1>
    </div>
    
    <h2 class="text-2xl md:text-4xl font-bold text-slate-900 dark:text-white mb-4 italic">
        "Model Hallucination Detected."
    </h2>
    
    <p class="text-slate-600 dark:text-slate-400 max-w-md mb-10 text-lg">
      The Generative Engine couldn't find a factual source for the URL you requested. It either never existed, or it’s been moved to a new digital entity.
    </p>
    
    <div class="flex flex-col sm:flex-row gap-4">
        <a href="/" class="text-lg font-bold bg-blue-600 text-white py-3 px-8 rounded-md inline-block hover:bg-blue-700 transition shadow-lg shadow-blue-600/20">
          Return to Source →
        </a>
        <a href="/journal" class="text-lg font-medium border border-slate-200 dark:border-slate-800 py-3 px-8 rounded-md inline-block hover:bg-slate-100 dark:hover:bg-slate-800 transition">
          Read Latest Intelligence
        </a>
    </div>
  </div>
</BaseLayout>