---
import BaseLayout from '../layouts/BaseLayout.astro';

// Updated JSON-LD Schema centered on Web Strategist & GEO Entity
const schemaData = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "mainEntity": {
    "@type": "Person",
    "name": "Phill Savage",
    "jobTitle": "Principal Web Strategist & Client Director",
    "url": "https://psavage.net",
    "image": "https://psavage.net/images/phill.jpg",
    "description": "Principal Web Strategist and Client Director at Ace Marketing Solutions in Chiang Mai, Thailand. Advising growth brands on digital architecture, conversion marketing, and Generative Engine Optimization (GEO).",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Chiang Mai",
      "addressCountry": "TH"
    },
    "knowsAbout": [
      "Web Strategy & Architecture",
      "Generative Engine Optimization (GEO)",
      "Growth & Performance Marketing",
      "Astro & Jamstack Development",
      "Client Leadership & Account Management"
    ],
    "worksFor": [
      {
        "@type": "Organization",
        "name": "Ace Marketing Solutions",
        "url": "https://acemsthailand.com"
      }
    ],
    "sameAs": [
      "https://acemsthailand.com",
      "https://x.com/savphill",
      "https://th.linkedin.com/in/phill-savage"
    ]
  }
};
---

<BaseLayout 
  title="About Phill Savage | Web Strategist & Growth Marketing Director" 
  description="About Phill Savage — Principal Web Strategist and Client Director at Ace Marketing Solutions in Chiang Mai, Thailand. Architecting high-converting web systems and GEO strategies for scaling tech brands."
  keywords={["Phill Savage", "Web Strategist Chiang Mai", "Generative Engine Optimization", "GEO Strategy Thailand", "Growth Marketing Director", "Ace Marketing Solutions"]}
>
  <!-- Injects JSON-LD Entity Schema for Search Engines & LLMs -->
  <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

  <div class="relative overflow-hidden">
    <!-- Background Glow FX -->
    <div class="absolute -top-40 -left-40 w-96 h-96 bg-blue-500/10 dark:bg-blue-600/15 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute top-1/3 -right-40 w-96 h-96 bg-cyan-500/10 dark:bg-cyan-500/15 rounded-full blur-3xl pointer-events-none"></div>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-20 relative z-10">
      
      <!-- HERO HEADER -->
      <header class="mb-12 pt-10" transition:animate="fade">
        <div class="flex flex-col md:flex-row gap-8 items-center md:items-start">
          <img 
            src="/images/phill.jpg" 
            alt="Phill Savage — Web Strategist & Client Director" 
            class="w-36 h-36 md:w-40 md:h-40 rounded-full object-cover ring-4 ring-blue-500/20 dark:ring-blue-400/30 shadow-2xl flex-shrink-0"
          />
          <div class="text-center md:text-left">
            <span class="inline-block text-xs font-mono font-bold uppercase tracking-widest text-blue-600 dark:text-blue-400 mb-2">
              // Web Strategist & Growth Architect
            </span>
            <h1 class="text-3xl sm:text-4xl md:text-5xl mb-4 font-black tracking-tight text-slate-900 dark:text-white leading-tight">
              Building high-ROI web systems in <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-cyan-500 dark:from-blue-400 dark:to-cyan-300">Chiang Mai & Thailand.</span>
            </h1>
            <p class="text-lg md:text-xl text-slate-600 dark:text-slate-300 max-w-2xl leading-relaxed">
              10+ years directing digital agency operations. Combining high-performance web architecture, conversion-focused growth marketing, and Generative Engine Optimization (GEO).
            </p>
          </div>
        </div>
      </header>

      <!-- KEY METRICS / PROOF BAR -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 py-6 mb-12 border-y border-slate-200/60 dark:border-slate-800/60" transition:animate="fade">
        <div class="text-center md:text-left">
          <span class="block text-3xl font-black text-slate-900 dark:text-white font-mono">10+</span>
          <span class="text-[11px] font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider">Years Marketing</span>
        </div>
        <div class="text-center md:text-left">
          <span class="block text-3xl font-black text-slate-900 dark:text-white font-mono">Chiang Mai</span>
          <span class="text-[11px] font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider">Primary HQ</span>
        </div>
        <div class="text-center md:text-left">
          <span class="block text-3xl font-black text-slate-900 dark:text-white font-mono">100+</span>
          <span class="text-[11px] font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider">Digital Campaigns</span>
        </div>
        <div class="text-center md:text-left">
          <span class="block text-3xl font-black text-slate-900 dark:text-white font-mono">Ace MS</span>
          <span class="text-[11px] font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider">Agency Directorship</span>
        </div>
      </div>

      <!-- MAIN BIO / PROSE STORY -->
      <div class="prose prose-lg dark:prose-invert max-w-3xl mb-16 text-slate-700 dark:text-slate-300 leading-relaxed" transition:animate="fade">
        <p>
          I’ve spent over a decade at the intersection of web architecture, growth marketing, and account direction—primarily leading agency initiatives as Client Director at <strong><a href="https://acemsthailand.com" class="text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300" target="_blank" rel="noopener noreferrer">Ace Marketing Solutions</a></strong> in Chiang Mai, Thailand.
        </p>
        
        <p>
          Throughout my career, I’ve overseen technical digital transformations and multi-channel acquisition strategies for <strong>over 100 brands</strong>—from scaling B2B tech platforms to high-end hospitality groups. That experience shaped my belief that a company's website should never act as a passive digital business card, but as a high-performing engine for predictable revenue.
        </p>

        <h2 class="text-2xl font-bold mt-10 mb-4 text-slate-900 dark:text-white">Navigating the AI Search Shift</h2>
        <p>
          As search behavior undergoes its biggest shift in two decades, standard SEO playbooks are rapidly losing momentum. Today's prospective customers no longer rely solely on blue search links—they ask **ChatGPT, Perplexity, Gemini, and Claude** for direct recommendations and summaries.
        </p>
        
        <p>
          Most brands remain unprepared for this shift. They continue dumping budget into slow, bloated CMS installations and generic content strategies that fail to establish true entity authority inside Large Language Models (LLMs).
        </p>

        <p>
          My advisory work focuses on bridging this exact gap. By coupling cutting-edge web architecture (utilizing modern frameworks like Astro) with **Generative Engine Optimization (GEO)**, I help founders and marketing teams structure their digital footprint so AI platforms consistently surface and cite their products as authoritative industry solutions.
        </p>
      </div>

      <!-- CORE FOCUS / PILLARS -->
      <section class="mb-16" transition:animate="fade">
        <div class="mb-6">
          <span class="text-xs font-mono uppercase tracking-widest text-blue-600 dark:text-blue-400 font-bold">// Strategic Capability</span>
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 dark:text-white mt-1">Core Pillars of Strategy</h2>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          
          <div class="bg-slate-50 dark:bg-slate-900/60 p-6 rounded-2xl border border-slate-200/80 dark:border-slate-800/80">
            <div class="text-xs font-mono text-blue-600 dark:text-blue-400 uppercase tracking-wider mb-2">// 01. Web Architecture & UX</div>
            <h3 class="font-bold text-lg text-slate-900 dark:text-white mb-2">High-Performance Jamstack Builds</h3>
            <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">
              We design and refactor websites for sub-second page loads, immaculate Core Web Vitals, and friction-free user flows using modern SSG and headless CMS setups.
            </p>
          </div>
          
          <div class="bg-slate-50 dark:bg-slate-900/60 p-6 rounded-2xl border border-slate-200/80 dark:border-slate-800/80">
            <div class="text-xs font-mono text-blue-600 dark:text-blue-400 uppercase tracking-wider mb-2">// 02. LLM Search Authority</div>
            <h3 class="font-bold text-lg text-slate-900 dark:text-white mb-2">Generative Engine Optimization (GEO)</h3>
            <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">
              Engineering JSON-LD schema graphs, brand entity signals, and authoritative content structures so generative AI search tools actively recommend your brand.
            </p>
          </div>
        
          <div class="bg-slate-50 dark:bg-slate-900/60 p-6 rounded-2xl border border-slate-200/80 dark:border-slate-800/80 md:col-span-2">
            <div class="text-xs font-mono text-blue-600 dark:text-blue-400 uppercase tracking-wider mb-2">// 03. Growth Marketing Execution</div>
            <h3 class="font-bold text-lg text-slate-900 dark:text-white mb-2">Agency-Backed Client Direction</h3>
            <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">
              Through my executive directorship at <a href="https://acemsthailand.com" target="_blank" rel="noopener noreferrer" class="underline hover:text-blue-600">Ace Marketing Solutions</a>, we provide full end-to-end execution—from messaging alignment and funnel optimization to multi-currency commercial invoicing and SLA support.
            </p>
          </div>

        </div>
      </section>

      <!-- CTA CARD -->
      <div class="bg-slate-900 text-white dark:bg-slate-900/90 border border-slate-800 rounded-2xl p-8 text-left shadow-2xl relative overflow-hidden" transition:animate="fade">
        <div class="absolute -right-10 -bottom-10 w-48 h-48 bg-blue-500/20 rounded-full blur-2xl pointer-events-none"></div>
        
        <h3 class="text-2xl font-bold text-white mb-2">Ready to modernize your digital web strategy?</h3>
        <p class="text-slate-300 mb-6 max-w-2xl leading-relaxed text-sm sm:text-base">
          Whether you need a full web performance rebuild, conversion rate optimization, or a GEO blueprint to capture AI search market share, let’s audit your site.
        </p>
        
        <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-4">
          <a 
            href="mailto:hello@psavage.net?subject=Web%20Strategy%20%26%20GEO%20Audit" 
            class="inline-flex items-center justify-center px-6 py-3 text-xs font-mono font-bold uppercase tracking-wider text-slate-900 bg-white hover:bg-slate-100 rounded-lg transition-colors text-center"
          >
            Email Phill Directly →
          </a>
          <a 
            href="https://acemsthailand.com" 
            target="_blank" 
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center px-6 py-3 text-xs font-mono font-bold uppercase tracking-wider text-white border border-slate-700 hover:border-slate-500 rounded-lg transition-colors text-center"
          >
            Visit Ace Marketing Solutions
          </a>
        </div>
      </div>

    </div>
  </div>
</BaseLayout>