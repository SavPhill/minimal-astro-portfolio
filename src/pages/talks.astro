---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostListWithThumbnails from '../components/PostListWithThumbnails.astro';
import { getCollection } from 'astro:content';

// Get all talks and sort them by date
const allTalks = await getCollection('talks');
const sortedTalks = allTalks.sort((a, b) => {
  return new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf();
});

// Format talks for the PostList component
const talks = sortedTalks.map(talk => ({
  ...talk,
  url: `/talks/${talk.id}`, // Routes to the new /talks/ directory
  frontmatter: talk.data
}));
---

<BaseLayout title="Talks & Presentations">
  <div class="max-w-3xl mx-auto">
    <header class="mb-12 text-center" transition:animate="fade">
      <h1 class="text-5xl mb-4 font-bold tracking-tight">Talks</h1>
      <p class="text-xl text-muted-foreground">
        Public presentations on Generative Search (GEO), WordPress Security, and Technical Architecture delivered at industry events.
      </p>
    </header>

    <div transition:animate="fade">
      <PostListWithThumbnails posts={talks} showTags={true} title="Public Presentations" />
    </div>
  </div>
</BaseLayout>