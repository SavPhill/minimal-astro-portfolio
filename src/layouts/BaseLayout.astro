---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import DarkModeToggle from '../components/ui/DarkModeToggle.astro';
import { SITE } from '../config/site';

interface Props {
  title: string;
  pageTitle?: string;
  description?: string;
  keywords?: string[];
  image?: string;
  type?: 'website' | 'article';
  publishedDate?: Date;
  modifiedDate?: Date;
  author?: string;
  schema?: Record<string, any>;
}

const { 
  title,
  pageTitle,
  description = SITE.description,
  keywords,
  image = "/images/og-default.png",
  type = "website",
  publishedDate,
  modifiedDate,
  author = SITE.author,
  schema
} = Astro.props;

// STRICT MODE FIX: Fallback to current request URL if Astro.site is undefined
const siteBase = Astro.site ?? Astro.url;
// STRICT MODE FIX: Explicitly convert URL objects to strings for HTML attributes
const canonicalURL = new URL(Astro.url.pathname, siteBase).toString();
const ogImageURL = image.startsWith('/') ? new URL(image, siteBase).toString() : image;
const siteUrlString = Astro.site?.toString() ?? Astro.url.origin;
const siteName = SITE.name;

// Complete Cross-Platform Entity Graph
const socialLinks = [
  "https://x.com/savphill",
  "https://github.com/savphill",
  "https://th.linkedin.com/in/phill-savage",
  "https://profiles.wordpress.org/phillsav/",
  "https://offsitethailand.com",
  "https://acemsthailand.com"
];

const jsonLDWebsite = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": siteName,
  "url": siteUrlString,
  "description": description,
  "author": {
    "@type": "Person",
    "name": author,
    "url": siteUrlString,
    "sameAs": socialLinks
  }
};

const activeSchema = schema ?? jsonLDWebsite;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle ?? (title === SITE.name || title === SITE.headline ? SITE.headline : `${title} | ${SITE.name}`)}</title>
    <meta name="description" content={description} />
    {keywords && keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}
    <link rel="canonical" href={canonicalURL} />

    <!-- Astro View Transitions -->
    <ClientRouter />

    <!-- Dark mode initialization -->
    <script is:inline>
      function applyTheme() {
        if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      }
      applyTheme();
      document.addEventListener('astro:after-swap', applyTheme);
    </script>
    
    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content={siteName} />

    <!-- Twitter / X -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:site" content="@savphill" />
    <meta property="twitter:creator" content="@savphill" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImageURL} />
    
    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(activeSchema)} />
    
    <style is:inline>
      body {
        font-family: 'Geist Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
      }
      code, pre, kbd, samp {
        font-family: 'Geist Mono', ui-monospace, SFMono-Regular, 'SF Mono', Menlo, Consolas, 'Liberation Mono', monospace;
      }
    </style>
  </head>
  <body class="text-slate-900 bg-white dark:text-slate-200 dark:bg-slate-950 transition-colors duration-300 min-h-screen">
    <div class="px-4 sm:px-6">
      <header class="mx-auto max-w-4xl py-6 md:py-8">
        <div class="flex items-center justify-between">
          <a href="/" class="text-2xl font-black tracking-tight text-slate-900 dark:text-white" transition:animate="fade">
            {SITE.name}
          </a>

          <!-- Focused Desktop Navigation -->
          <div class="hidden md:flex items-center gap-8">
            <nav class="flex items-center gap-6 font-medium text-sm text-slate-700 dark:text-slate-300">
              <a href="/" class="hover:text-cyan-500 dark:hover:text-cyan-400 transition-colors">Home</a>
              <a href="/about" class="hover:text-cyan-500 dark:hover:text-cyan-400 transition-colors">About</a>
              <a href="/journal" class="hover:text-cyan-500 dark:hover:text-cyan-400 transition-colors">Blog</a>
              <a href="/remote" class="hover:text-cyan-500 dark:hover:text-cyan-400 transition-colors">Strategy Consulting</a>
              <a href="/security" class="hover:text-cyan-500 dark:hover:text-cyan-400 transition-colors">Security</a>
            </nav>
            <DarkModeToggle />
          </div>

          <!-- Mobile Navigation Controls -->
          <div class="md:hidden flex items-center gap-3">
            <DarkModeToggle />
            <button
              id="mobile-menu-button"
              type="button"
              class="inline-flex items-center justify-center p-3 -mr-2 rounded-xl text-slate-900 dark:text-slate-200 hover:bg-slate-100 dark:hover:bg-slate-800/80 focus:outline-none transition-colors touch-manipulation cursor-pointer"
              aria-expanded="false"
              aria-label="Toggle menu"
            >
              <svg id="menu-icon" class="block h-6 w-6 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
              </svg>
              <svg id="close-icon" class="hidden h-6 w-6 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>
        </div>

        <!-- Accessible & Touch-Optimized Mobile Navigation -->
        <nav id="mobile-menu" class="hidden md:hidden mt-4 pt-4 border-t border-slate-200 dark:border-slate-800 space-y-2">
          <a href="/" class="block px-4 py-3 rounded-lg text-base font-medium text-slate-900 dark:text-slate-100 bg-slate-50 dark:bg-slate-900/60 border border-slate-200/60 dark:border-slate-800/60 hover:text-cyan-500 active:bg-cyan-500/10 transition-colors touch-manipulation">
            Home
          </a>
          <a href="/about" class="block px-4 py-3 rounded-lg text-base font-medium text-slate-900 dark:text-slate-100 bg-slate-50 dark:bg-slate-900/60 border border-slate-200/60 dark:border-slate-800/60 hover:text-cyan-500 active:bg-cyan-500/10 transition-colors touch-manipulation">
            About
          </a>
          <a href="/journal" class="block px-4 py-3 rounded-lg text-base font-medium text-slate-900 dark:text-slate-100 bg-slate-50 dark:bg-slate-900/60 border border-slate-200/60 dark:border-slate-800/60 hover:text-cyan-500 active:bg-cyan-500/10 transition-colors touch-manipulation">
            Blog
          </a>
          <a href="/remote" class="block px-4 py-3 rounded-lg text-base font-medium text-slate-900 dark:text-slate-100 bg-slate-50 dark:bg-slate-900/60 border border-slate-200/60 dark:border-slate-800/60 hover:text-cyan-500 active:bg-cyan-500/10 transition-colors touch-manipulation">
            Strategy Consulting
          </a>
          <a href="/security" class="block px-4 py-3 rounded-lg text-base font-medium text-slate-900 dark:text-slate-100 bg-slate-50 dark:bg-slate-900/60 border border-slate-200/60 dark:border-slate-800/60 hover:text-cyan-500 active:bg-cyan-500/10 transition-colors touch-manipulation">
            Security
          </a>
        </nav>
      </header>
      
      <main class="py-6" transition:animate="fade">
        <slot />
      </main>
      
      <!-- FOOTER -->
      <footer class="max-w-4xl mx-auto py-8 border-t border-slate-200 dark:border-slate-800 mt-12">
        <div class="flex flex-col md:flex-row justify-between items-center gap-4">
          <div class="text-xs font-mono text-slate-500">
            © {new Date().getFullYear()} {SITE.name} • Chiang Mai, Thailand
          </div>
          
          <div class="flex flex-col sm:flex-row items-center gap-4 sm:gap-6">
            <nav class="flex items-center gap-4 text-xs font-mono text-slate-600 dark:text-slate-400">
              <a href="/about" class="hover:underline">About</a>
              <a href="/about" class="hover:underline">Blog</a>
              <a href="/remote" class="hover:underline">Strategy Consulting</a>
              <a href="/security" class="hover:underline">Security</a>
              <a href="https://acemsthailand.com" target="_blank" rel="noopener noreferrer" class="hover:underline text-cyan-600 dark:text-cyan-400 font-semibold">Ace MS ↗</a>
            </nav>

            <!-- Entity Links -->
            <div class="flex items-center gap-3.5 sm:border-l border-slate-200 dark:border-slate-800 sm:pl-4">
              <a href="https://x.com/savphill" target="_blank" rel="noopener noreferrer" aria-label="X / Twitter" class="text-slate-500 hover:text-cyan-400 transition-colors">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              </a>
              <a href="https://github.com/savphill" target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="text-slate-500 hover:text-cyan-400 transition-colors">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
              </a>
              <a href="https://th.linkedin.com/in/phill-savage" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="text-slate-500 hover:text-cyan-400 transition-colors">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
              </a>
            </div>
          </div>
        </div>
      </footer>
    </div>

    <script>
      function setupMobileMenu() {
        // Cast to HTMLButtonElement so TypeScript knows it has standard button properties/methods
        const menuButton = document.getElementById('mobile-menu-button') as HTMLButtonElement | null;
        const mobileMenu = document.getElementById('mobile-menu');
        const menuIcon = document.getElementById('menu-icon');
        const closeIcon = document.getElementById('close-icon');

        if (!menuButton || !mobileMenu || !menuIcon || !closeIcon) return;

        // Clone node to safely reset event listeners during View Transitions
        const newButton = menuButton.cloneNode(true) as HTMLButtonElement;
        if (menuButton.parentNode) {
          menuButton.parentNode.replaceChild(newButton, menuButton);
        }

        newButton.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          // Use standard camelCase getAttribute
          const isExpanded = newButton.getAttribute('aria-expanded') === 'true';
          
          mobileMenu.classList.toggle('hidden');
          menuIcon.classList.toggle('hidden');
          closeIcon.classList.toggle('hidden');
          newButton.setAttribute('aria-expanded', String(!isExpanded));
        });

        // Close menu automatically on mobile link tap
        const mobileLinks = mobileMenu.querySelectorAll('a');
        mobileLinks.forEach(link => {
          link.addEventListener('click', () => {
            mobileMenu.classList.add('hidden');
            menuIcon.classList.remove('hidden');
            closeIcon.classList.add('hidden');
            newButton.setAttribute('aria-expanded', 'false');
          });
        });
      }

      function setupThemeToggle() {
        const buttons = document.querySelectorAll('.theme-toggle');
        buttons.forEach(button => {
          const newBtn = button.cloneNode(true);
          if (button.parentNode) {
            button.parentNode.replaceChild(newBtn, button);
          }
          
          newBtn.addEventListener('click', () => {
            if (document.documentElement.classList.contains('dark')) {
              localStorage.theme = 'light';
              document.documentElement.classList.remove('dark');
            } else {
              localStorage.theme = 'dark';
              document.documentElement.classList.add('dark');
            }
          });
        });
      }

      // Initial run
      setupMobileMenu();
      setupThemeToggle();

      // Astro View Transition Lifecycle Hooks
      document.addEventListener('astro:after-swap', () => {
        setupMobileMenu();
        setupThemeToggle();
      });
      document.addEventListener('astro:page-load', () => {
        setupMobileMenu();
        setupThemeToggle();
      });
    </script>
  </body>
</html>