---
import BaseLayout from './BaseLayout.astro';
import { formatDate } from '../utils/date';
import { optimizeImagePath } from '../utils/optimizeImagePath';
import { SITE } from '../config/site';

const { frontmatter } = Astro.props;
const { title, date, tags, image, excerpt, metaTitle, metaDescription, keywords } = frontmatter;
const slug = Astro.url.pathname.split('/').filter(Boolean).pop();

// Ensure image path is optimized
const optimizedImagePath = image ? optimizeImagePath(image) : null;

// Estimated reading time
const WORDS_PER_MINUTE = 225;
const content = await Astro.slots.render('default');
const contentText = content.replace(/<\/?[^>]+(>|$)/g, ' ');
const wordCount = contentText.split(/\s+/).length;
const readingTime = Math.max(1, Math.ceil(wordCount / WORDS_PER_MINUTE));

const publishDate = new Date(date);
---

<BaseLayout
  title={title}
  pageTitle={metaTitle ? `${metaTitle} | ${SITE.name}` : undefined}
  description={metaDescription ?? excerpt}
  keywords={keywords}
  image={optimizedImagePath || image}
  type="article"
  publishedDate={publishDate}
>
  <article id="main-content" class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <header class="max-w-3xl mx-auto mb-10 text-left">
      <div class="flex items-center gap-3 text-xs font-mono text-cyan-600 dark:text-cyan-400 mb-4">
        <time datetime={publishDate.toISOString()}>{formatDate(date)}</time>
        <span class="text-slate-400 dark:text-slate-600">•</span>
        <span class="text-slate-600 dark:text-slate-400">{readingTime} min read</span>
      </div>

      <!-- Adaptive Heading: Dark Slate in Light Mode, Pure White in Dark Mode -->
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-black text-slate-900 dark:text-white tracking-tight leading-tight mb-6" transition:name={`title-${slug}`}>
        {title}
      </h1>

      {excerpt && (
        <p class="text-lg sm:text-xl text-slate-700 dark:text-slate-300 leading-relaxed font-normal">
          {excerpt}
        </p>
      )}

      <!-- TAG BADGES -->
      {tags && tags.length > 0 && (
        <div class="mt-6 flex flex-wrap gap-2" aria-label="Tags">
          {tags.map((tag: string) => (
            <span class="text-[11px] font-mono px-3 py-1 rounded-full bg-slate-100 dark:bg-slate-900/80 text-cyan-700 dark:text-cyan-300 border border-slate-300 dark:border-slate-800">
              #{tag}
            </span>
          ))}
        </div>
      )}
    </header>

    {optimizedImagePath && (
      <div class="max-w-4xl mx-auto my-10 rounded-2xl overflow-hidden border border-slate-200 dark:border-slate-800/80 shadow-2xl bg-slate-100 dark:bg-slate-900" transition:name={`image-${slug}`}>
        <img
          src={optimizedImagePath}
          alt={`Featured image for "${title}"`}
          class="w-full h-auto object-cover max-h-[480px]"
          loading="eager"
          decoding="async"
          width="1200"
          height="675"
        />
      </div>
    )}

    <!-- ARTICLE BODY (Dynamic Prose Colors) -->
    <div class="max-w-3xl mx-auto prose prose-slate dark:prose-invert prose-lg leading-relaxed dark:prose-headings:text-white prose-a:text-cyan-600 dark:prose-a:text-cyan-400 prose-a:no-underline hover:prose-a:underline dark:prose-strong:text-white dark:prose-code:text-cyan-300">
      <slot />
    </div>

    <!-- HIGH-CONVERTING OFFSITE CTA HOOK -->
    <div class="max-w-3xl mx-auto mt-20">
      <section class="p-6 sm:p-8 rounded-2xl bg-slate-900 text-white border border-cyan-500/20 shadow-2xl flex flex-col md:flex-row items-center justify-between gap-6">
        <div class="space-y-2 max-w-xl text-left">
          <span class="text-xs font-mono font-bold uppercase tracking-wider text-cyan-400">// Offsite Thailand</span>
          <h3 class="text-xl font-extrabold tracking-tight text-white">
            Planning a retreat for your remote team?
          </h3>
          <p class="text-xs sm:text-sm text-slate-300 leading-relaxed">
            We curate high-speed fiber workspaces, private luxury villas, and authentic cultural experiences across Chiang Mai, Phuket, and Bangkok.
          </p>
        </div>
        <div class="shrink-0 w-full md:w-auto text-center">
          <a 
            href="/#offsite-inquiry" 
            class="inline-block w-full md:w-auto bg-gradient-to-r from-blue-500 to-cyan-500 text-white px-6 py-3 rounded-xl font-mono text-xs font-bold uppercase tracking-wider hover:from-blue-400 hover:to-cyan-400 transition-all shadow-lg shadow-cyan-500/20"
          >
            Request Proposal →
          </a>
        </div>
      </section>
    </div>
  </article>
</BaseLayout>