---
import BaseLayout from './BaseLayout.astro';
import PostNavigation from '../components/PostNavigation.astro';
import { formatDate } from '../utils/date';
import { optimizeImagePath } from '../utils/optimizeImagePath';
import { SITE } from '../config/site';

const { frontmatter, headings, prevPost, nextPost } = Astro.props;
const { title, date, tags, image, excerpt, metaTitle, metaDescription, keywords } = frontmatter;
const slug = Astro.url.pathname.split('/').filter(Boolean).pop();

// Ensure image path is optimized
const optimizedImagePath = image ? optimizeImagePath(image) : null;

// Estimated reading time
const WORDS_PER_MINUTE = 225;
const content = await Astro.slots.render('default');
const contentText = content.replace(/<\/?[^>]+(>|$)/g, ' ');
const wordCount = contentText.split(/\s+/).length;
const readingTime = Math.max(1, Math.ceil(wordCount / WORDS_PER_MINUTE));

// Structured data for SEO
const publishDate = new Date(date);
---

<BaseLayout
  title={title}
  pageTitle={metaTitle ? `${metaTitle} | ${SITE.name}` : undefined}
  description={metaDescription ?? excerpt}
  keywords={keywords}
  image={optimizedImagePath || image}
  type="article"
  publishedDate={publishDate}
>
  <article id="main-content">
    <header class="max-w-3xl mx-auto mb-10">
      <div class="text-gray-500 text-sm mb-2">
        <time datetime={publishDate.toISOString()}>{formatDate(date)}</time> • <span aria-label={`${readingTime} minute read`}>{readingTime} min read</span>
      </div>
      <h1 class="text-5xl mb-6" transition:name={`title-${slug}`}>{title}</h1>
      {excerpt && <p class="text-xl text-gray-500">{excerpt}</p>}

      {tags && tags.length > 0 && (
        <div class="mt-4 mb-4 flex flex-wrap gap-2" aria-label="Tags">
          {tags.map((tag) => (
            <a
              href={`/tags/${tag}`}
              class="tag"
              aria-label={`View all posts tagged ${tag}`}
            >
              {tag}
            </a>
          ))}
        </div>
      )}
    </header>

    {optimizedImagePath && (
      <div class="max-w-4xl mx-auto mt-2 mb-10 feature-image" transition:name={`image-${slug}`}>
        <img
          src={optimizedImagePath}
          alt={`Featured image for "${title}"`}
          class="w-full h-full object-cover"
          loading="eager"
          decoding="async"
          width="1200"
          height="675"
        />
      </div>
    )}

    <div class="max-w-3xl mx-auto prose prose-xl">
      <slot />
    </div>

    <!-- INBOUND CONSULTING HOOK -->
    <div class="max-w-3xl mx-auto mt-16 mb-12">
      <section class="p-8 rounded-xl bg-gray-50 dark:bg-zinc-900 border border-gray-100 dark:border-zinc-800 flex flex-col md:flex-row items-center justify-between gap-6">
        <div class="space-y-2 max-w-xl">
          <h3 class="text-xl font-bold tracking-tight text-gray-900 dark:text-white">
            Is your brand invisible to machine buyers?
          </h3>
          <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed">
            Stop wasting capital on commodity content production. Let's look at your actual indexing footprints, schema layers, and LLM entity validation with a technical visibility audit.
          </p>
        </div>
        <div class="shrink-0 w-full md:w-auto text-center">
          <a 
            href={`mailto:hello@psavage.net?subject=AI%20Search%20Optimization%20Inquiry%20—%20${encodeURIComponent(title)}`} 
            class="inline-block w-full md:w-auto bg-blue-600 text-white px-6 py-3 rounded-md font-bold no-underline hover:bg-blue-700 transition duration-300 shadow-md shadow-blue-600/10"
          >
            Schedule a chat with Phill
          </a>
        </div>
      </section>
    </div>

    <div class="max-w-3xl mx-auto">
      <PostNavigation prevPost={prevPost} nextPost={nextPost} />
    </div>
  </article>
</BaseLayout>